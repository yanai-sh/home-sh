{
  "name": "yanai-sh",
  "version": "2.0.0",
  "private": true,
  "description": "Personal portfolio — yanai.sh monorepo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanai-sh/yanai-sh.github.io.git"
  },
  "type": "module",
  "scripts": {
    "setup:wsl": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/wsl-run.ps1 bash scripts/wsl-setup.sh",
    "dev": "node scripts/wsl-proxy.mjs nub run -F @yanai-sh/site dev",
    "dev:fresh": "node scripts/wsl-proxy.mjs nub run -F @yanai-sh/site dev:fresh",
    "check:dev": "node scripts/wsl-proxy.mjs nub run -F @yanai-sh/site check:dev",
    "build": "node scripts/wsl-proxy.mjs nub run -F @yanai-sh/site build",
    "check": "node scripts/wsl-proxy.mjs nub run -F @yanai-sh/site check",
    "fix": "node scripts/wsl-proxy.mjs nub run -F @yanai-sh/site fix",
    "typecheck": "node scripts/wsl-proxy.mjs nub run -F @yanai-sh/site typecheck",
    "test": "node scripts/wsl-proxy.mjs nub run -F @yanai-sh/site test",
    "verify": "NODE_COMPAT=1 node scripts/wsl-proxy.mjs sh scripts/verify-with-progress.sh",
    "preview": "node scripts/wsl-proxy.mjs nub run -F @yanai-sh/site preview",
    "smoke": "node scripts/wsl-proxy.mjs nub run -F @yanai-sh/site smoke",
    "env:copy-prod": "node scripts/wsl-proxy.mjs nub exec tsx scripts/copy-gh-environment.ts --from staging --to production",
    "cf:list-access-apps": "node scripts/wsl-proxy.mjs nub exec tsx scripts/cf-list-access-apps.ts",
    "push-secrets": "node scripts/wsl-proxy.mjs nub exec tsx scripts/push-secrets.ts",
    "destroy-legacy-data": "node scripts/wsl-proxy.mjs nub exec tsx scripts/destroy-legacy-data-stores.ts",
    "optional:bitwarden-to-secrets": "node scripts/wsl-proxy.mjs nub exec tsx scripts/optional/bitwarden-to-secrets.ts",
    "prepare": "node scripts/wsl-proxy.mjs sh -c \"command -v git >/dev/null 2>&1 && nub exec lefthook install || exit 0\""
  },
  "devDependencies": {
    "lefthook": "^2.1.9",
    "playwright": "^1.60.0",
    "tsx": "^4.21.0",
    "vite-plus": "^0.2.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "nub@0.1.10",
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.1.10",
      "onFail": "warn"
    }
  },
  "workspaces": [
    "apps/site"
  ],
  "allowBuilds": {
    "esbuild": true,
    "lefthook": true,
    "sharp": true,
    "workerd": true
  }
}
