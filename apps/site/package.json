{
  "name": "@yanai-sh/site",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wrangler-types": "wrangler types ./src/worker-configuration.d.ts && bun run ./scripts/patch-worker-configuration-env.ts",
    "dev": "astro dev --host ::",
    "build": "bun run wrangler-types && astro build",
    "check": "biome check ./src ./scripts astro.config.mjs package.json",
    "fix": "biome check --write ./src ./scripts astro.config.mjs package.json",
    "typecheck": "bun run wrangler-types && astro check",
    "test": "bun test ./src",
    "verify": "bun run check && bun run typecheck && bun run test && bun run build",
    "preview": "astro preview",
    "smoke": "playwright test --config=tests/smoke/playwright.config.ts",
    "version-upload": "wrangler versions upload --config dist/server/wrangler.json",
    "version-deploy": "wrangler versions deploy --config dist/server/wrangler.json"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.0",
    "@astrojs/mdx": "^6.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.2",
    "astro-icon": "^1.1.5",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/ts-plugin": "^1.10.9",
    "@biomejs/biome": "^2.4.16",
    "@iconify-json/devicon": "^1.2.62",
    "@iconify-json/mdi": "^1.2.3",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.96.0"
  }
}
