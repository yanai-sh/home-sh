{
  "name": "@yanai-sh/site",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "velite": "velite build",
    "wrangler-types": "rm -f ./src/worker-configuration.d.ts && wrangler types ./src/worker-configuration.d.ts && tsx ./scripts/patch-worker-configuration-env.ts",
    "dev": "pnpm velite && vp dev",
    "build": "pnpm velite && pnpm wrangler-types && vp build",
    "check": "vp check",
    "fix": "vp check --fix",
    "typecheck": "pnpm wrangler-types && vp check --typecheck-only",
    "test": "vitest run --config vitest.config.ts",
    "verify": "pnpm velite && vp check && vitest run --config vitest.config.ts && vp build",
    "preview": "vp preview",
    "smoke": "playwright test --config=tests/smoke/playwright.config.ts",
    "version-upload": "wrangler versions upload --config dist/yanai_sh/wrangler.json",
    "version-deploy": "wrangler versions deploy --config dist/yanai_sh/wrangler.json"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.39.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@tailwindcss/vite": "^4.3.0",
    "hono": "^4.11.3",
    "tailwindcss": "^4.3.0",
    "velite": "^0.2.4",
    "vite-plus": "^0.1.23",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260609.0",
    "playwright": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.0",
    "wrangler": "^4.100.0"
  }
}
