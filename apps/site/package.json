{
  "name": "@yanai-sh/site",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wrangler-types": "wrangler types ./src/worker-configuration.d.ts && bun run ./scripts/patch-worker-configuration-env.ts",
    "dev": "bun run wrangler-types && panda codegen && astro dev --host 127.0.0.1",
    "build": "bun run wrangler-types && panda codegen && astro build",
    "check": "biome check ./src ./scripts astro.config.mjs package.json",
    "fix": "biome check --write ./src ./scripts astro.config.mjs package.json",
    "typecheck": "bun run wrangler-types && panda codegen && astro check",
    "test": "bun test ./src",
    "verify": "bun run check && bun run typecheck && bun run test && bun run build",
    "preview": "astro preview",
    "smoke": "playwright test --config=tests/smoke/playwright.config.ts",
    "version-upload": "wrangler versions upload --config dist/server/wrangler.json",
    "version-deploy": "wrangler versions deploy --config dist/server/wrangler.json"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@yanai-sh/ui-system": "workspace:*",
    "astro": "^6.3.1",
    "gsap": "^3.15.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/ts-plugin": "^1.10.7",
    "@biomejs/biome": "^2.4.15",
    "@pandacss/dev": "^1.11.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.2",
    "@types/three": "^0.184.0",
    "postcss": "^8.5.14",
    "typescript": "^6.0.3",
    "wrangler": "^4.88.0"
  }
}
