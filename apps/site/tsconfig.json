{
  "extends": "astro/tsconfigs/strict",
  "exclude": ["public/wasm/**/*.js", "dist"],
  "compilerOptions": {
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@components/*": [
        "src/components/*"
      ],
      "@layouts/*": [
        "src/layouts/*"
      ],
      "@lib/*": [
        "src/lib/*"
      ],
      "@config/*": [
        "src/config/*"
      ],
      "@/*": [
        "src/*"
      ]
    },
    "types": ["@astrojs/cloudflare", "bun", "node"],
    "strict": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true
  }
}
