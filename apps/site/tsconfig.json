{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "types": ["vite/client", "@cloudflare/workers-types", "node"],
    "baseUrl": ".",
    "paths": {
      "@resume/generated": ["../../content/resume.generated.json"],
      "@components/*": ["src/components/*"],
      "@views/*": ["src/views/*"],
      "@lib/*": ["src/lib/*"],
      "@config/*": ["src/config/*"],
      "@/*": ["src/*"],
      "#content": [".velite/index.d.ts", ".velite/index.js"]
    }
  },
  "include": ["src", "vite.config.ts", "velite.config.ts"],
  "exclude": ["public/wasm/**/*.js", "dist", ".velite"]
}
