---
import Background from "@components/Background.astro";
import ContactForm from "@components/ContactForm.astro";
import EmailPill from "@components/EmailPill.astro";
import Footer from "@components/Footer.astro";
import Hero from "@components/Hero.astro";
import Lede from "@components/Lede.astro";
import ResumeShowcase from "@components/ResumeShowcase.astro";
import SceneCanvas from "@components/SceneCanvas.astro";
import Socials from "@components/Socials.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@config/site";
import Layout from "@layouts/Layout.astro";
import { footerEdgeProps } from "@lib/footer-edge";

const footer = footerEdgeProps(Astro.request);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Background />
  <SceneCanvas />
  <main class="page-shell" id="main-content" tabindex="-1">
    <section class="chapter chapter--home" data-bg-variant="home" aria-labelledby="hero-title">
      <div class="home-motion">
        <span class="roll-index" aria-hidden="true">01</span>
        <p class="chapter-kicker" aria-hidden="true">01 / home</p>
        <div class="hero-headline-slot">
          <Hero />
        </div>
        <div class="home-actions">
          <Lede />
          <EmailPill />
          <Socials />
        </div>
      </div>
      <a class="scroll-cue" href="#resume" aria-label="Scroll to resume">
        <span aria-hidden="true"></span>
      </a>
    </section>
    <ResumeShowcase />
    <ContactForm />
  </main>

  <Footer {...footer} />
</Layout>

<style>
  .page-shell {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-sizing: border-box;
    width: 100%;
    max-width: 100vw;
    min-width: 0;
    perspective: 1200px;
  }

  .chapter {
    position: relative;
    width: 100%;
    min-width: 0;
    isolation: isolate;
    overflow: clip;
  }

  .chapter--home {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding:
      clamp(var(--spacing-48), 7vh, var(--spacing-96))
      max(var(--spacing-16), min(var(--spacing-48), 5vi))
      calc(clamp(var(--spacing-48), 9vh, var(--spacing-96)) + env(safe-area-inset-bottom, 0px));
    box-sizing: border-box;
    transform-style: preserve-3d;
  }

  .home-motion {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding:
      clamp(var(--spacing-48), 7vh, var(--spacing-96))
      max(var(--spacing-16), min(var(--spacing-48), 5vi))
      calc(clamp(var(--spacing-48), 9vh, var(--spacing-96)) + env(safe-area-inset-bottom, 0px));
    box-sizing: border-box;
  }

  :global(html.has-scroll-scene) .home-motion {
    position: fixed;
    inset: 0;
    z-index: 10;
    transform-style: preserve-3d;
    will-change: transform, opacity;
  }

  :global(html.has-scroll-scene) .hero-headline-slot,
  :global(html.has-scroll-scene) .home-actions {
    transform-style: preserve-3d;
    will-change: transform, opacity;
  }

  .chapter-kicker {
    align-self: stretch;
    max-width: min(72rem, 100%);
    margin: 0 auto clamp(var(--spacing-24), 5vh, var(--spacing-64));
    color: rgba(245, 245, 247, 0.36);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1;
    text-align: left;
  }

  .roll-index {
    position: absolute;
    top: clamp(var(--spacing-24), 7vh, var(--spacing-64));
    right: max(var(--spacing-16), min(var(--spacing-64), 6vi));
    z-index: -1;
    color: rgba(245, 247, 250, 0.095);
    font-size: clamp(8rem, 28vi, 24rem);
    font-weight: 800;
    line-height: 0.74;
    letter-spacing: 0;
    pointer-events: none;
    transform: rotate(-5deg);
    user-select: none;
  }

  .hero-headline-slot {
    align-self: stretch;
    width: 100%;
    min-width: 0;
  }

  .home-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: min(32rem, 100%);
    min-width: 0;
  }

  .scroll-cue {
    position: absolute;
    left: 50%;
    bottom: max(var(--spacing-48), calc(var(--spacing-32) + env(safe-area-inset-bottom, 0px)));
    z-index: 12;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    color: color-mix(in srgb, var(--colors-fg) 62%, transparent);
    text-decoration: none;
    transform: translateX(-50%);
    transition:
      color 0.2s ease,
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .scroll-cue::before {
    content: "";
    position: absolute;
    inset: 0.45rem;
    border: 1px solid rgba(245, 245, 247, 0.12);
    border-radius: 999px;
    background: rgba(10, 15, 24, 0.28);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .scroll-cue span {
    position: relative;
    z-index: 1;
    width: 0.56rem;
    height: 0.56rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: translateY(-0.12rem) rotate(45deg);
    animation: cue-drift 1.7s ease-in-out infinite;
  }

  .scroll-cue:hover,
  .scroll-cue:focus-visible {
    color: var(--colors-accent);
    opacity: 1;
    transform: translateX(-50%) translateY(0.15rem);
  }

  .scroll-cue:focus-visible {
    outline: 1px dashed color-mix(in srgb, var(--colors-accent) 72%, transparent);
    outline-offset: 0.15rem;
  }

  @keyframes cue-drift {
    0%,
    100% {
      opacity: 0.46;
      transform: translateY(-0.18rem) rotate(45deg);
    }

    50% {
      opacity: 1;
      transform: translateY(0.16rem) rotate(45deg);
    }
  }

  @media (max-width: 640px) {
    .chapter--home {
      min-height: 100dvh;
      padding-top: var(--spacing-48);
      justify-content: center;
    }

    .chapter-kicker {
      margin-bottom: var(--spacing-32);
    }

    .roll-index {
      top: var(--spacing-48);
      right: var(--spacing-16);
      font-size: clamp(7rem, 34vi, 12rem);
    }

    .scroll-cue {
      bottom: max(var(--spacing-32), calc(var(--spacing-16) + env(safe-area-inset-bottom, 0px)));
    }
  }

  @media (max-height: 520px) and (orientation: landscape) {
    .chapter--home {
      min-height: auto;
      padding-top: var(--spacing-24);
      padding-bottom: calc(var(--spacing-48) + env(safe-area-inset-bottom, 0px));
    }

    .home-motion {
      position: relative;
      inset: auto;
      min-height: auto;
      padding-top: var(--spacing-24);
      padding-bottom: calc(var(--spacing-48) + env(safe-area-inset-bottom, 0px));
      transform: none;
      opacity: 1;
    }

    .chapter-kicker {
      margin-bottom: var(--spacing-16);
    }

    .home-actions {
      width: min(28rem, 100%);
    }

    .scroll-cue {
      display: none;
    }

    .home-actions :global(.email-block) {
      margin-bottom: var(--spacing-8);
    }

    .home-actions :global(.socials) {
      padding-top: 0;
    }
  }

  @supports (animation-timeline: scroll()) {
    @media (min-width: 900px) and (min-height: 520px) and (prefers-reduced-motion: no-preference) {
      @keyframes fallback-home-roll {
        from {
          opacity: 1;
          transform: translateY(0) rotateX(0) scale(1);
        }

        to {
          opacity: 0.72;
          transform: translateY(-8rem) rotateX(10deg) scale(0.98);
        }
      }

      @keyframes fallback-actions-roll {
        from {
          opacity: 1;
          transform: translateY(0);
        }

        to {
          opacity: 0.6;
          transform: translateY(-2.5rem);
        }
      }

      @keyframes fallback-contact-reveal {
        from {
          opacity: 0.55;
          transform: translateY(5rem) rotateX(-8deg) scale(0.98);
        }

        to {
          opacity: 1;
          transform: translateY(0) rotateX(0) scale(1);
        }
      }

      @keyframes fallback-resume-reveal {
        from {
          opacity: 0.36;
          transform: translateY(4rem) rotateX(-4deg) scale(0.985);
        }

        to {
          opacity: 1;
          transform: translateY(0) rotateX(0) scale(1);
        }
      }

      :global(html:not(.has-scroll-scene)) .home-motion {
        animation: fallback-home-roll linear both;
        animation-timeline: scroll(root block);
        animation-range: 0 90dvh;
        transform-origin: 50% 72%;
      }

      :global(html:not(.has-scroll-scene)) .home-actions {
        animation: fallback-actions-roll linear both;
        animation-timeline: scroll(root block);
        animation-range: 0 80dvh;
      }

      :global(html:not(.has-scroll-scene) .contact-stage) {
        animation: fallback-contact-reveal linear both;
        animation-timeline: view(block);
        animation-range: entry 0% cover 46%;
        transform-origin: 50% 16%;
      }

      :global(html:not(.has-scroll-scene) .resume-showcase) {
        animation: fallback-resume-reveal linear both;
        animation-timeline: view(block);
        animation-range: entry 0% cover 34%;
        transform-origin: 50% 8%;
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-headline-slot,
    .home-motion,
    .home-actions,
    .scroll-cue,
    .roll-index {
      animation: none;
      filter: none;
      transform: none;
      will-change: auto;
      opacity: 1;
    }
  }
</style>

<script>
  import { mountResumeNavigation } from "@lib/resume-nav-client";

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", mountResumeNavigation, { once: true });
  } else {
    mountResumeNavigation();
  }
</script>
