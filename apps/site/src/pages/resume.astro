---
import Background from "@components/Background.astro";
import Footer from "@components/Footer.astro";
import Layout from "@layouts/Layout.astro";
import { footerEdgeProps } from "@lib/footer-edge";
import { getEntry } from "astro:content";
import generated from "../../../../content/resume.generated.json";

const entry = await getEntry("resume", "current");
if (!entry) throw new Error("missing 'resume.current' content entry");
const resume = entry.data;
const source = generated.source as {
  url: string;
  path: string;
  commitSha: string | null;
  fallback: boolean;
};
const footer = footerEdgeProps(Astro.request);
const pageTitle = `${resume.header.name} — resume`;
const pageDescription = `${resume.header.name}, ${resume.header.headline}.`;
const primaryExperience = resume.experience.slice(0, 3);
const skillGroups = Object.entries(resume.skills);
const sourceLabel = source.fallback ? "fallback snapshot" : "synced source";
const sourceDetail = source.commitSha ? source.commitSha.slice(0, 7) : source.path;
---

<Layout title={pageTitle} description={pageDescription}>
  <Background />

  <main class="resume-shell" id="main-content" tabindex="-1">
    <aside class="resume-rail" aria-label="Resume summary">
      <p class="chapter-kicker">resume / source</p>
      <h1>{resume.header.name}</h1>
      <p class="headline">{resume.header.headline}</p>

      <dl class="contact-list">
        <div>
          <dt>email</dt>
          <dd><a href={`mailto:${resume.header.email}`}>{resume.header.email}</a></dd>
        </div>
        {resume.header.location ? (
          <div>
            <dt>location</dt>
            <dd>{resume.header.location}</dd>
          </div>
        ) : null}
        <div>
          <dt>source</dt>
          <dd>
            <a href={source.url}>{sourceLabel}</a>
            <span>{sourceDetail}</span>
          </dd>
        </div>
      </dl>

      <nav class="resume-actions" aria-label="Resume actions">
        <a class="action action--primary" href="/resume.pdf" download>Download PDF</a>
        <a class="action" href="/">Home</a>
      </nav>
    </aside>

    <article class="resume-document" aria-labelledby="resume-title">
      <header class="resume-header">
        <p class="chapter-kicker">static resume</p>
        <h2 id="resume-title">Forward deployment, systems integration, customer engineering.</h2>
        <p>{resume.summary}</p>
      </header>

      <section class="resume-section" aria-labelledby="experience-title">
        <div class="section-heading">
          <span>01</span>
          <h2 id="experience-title">Experience</h2>
        </div>

        <ol class="timeline">
          {primaryExperience.map((job) => (
            <li>
              <article class="entry">
                <header>
                  <p class="period">{job.period}</p>
                  <h3>{job.role}</h3>
                  <p class="meta">
                    {job.company}
                    {job.subtitle ? ` / ${job.subtitle}` : ""}
                    {job.location ? ` / ${job.location}` : ""}
                  </p>
                </header>
                <ul>
                  {job.highlights.slice(0, 5).map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
                {job.skills.length > 0 ? (
                  <p class="tags">{job.skills.join(" / ")}</p>
                ) : null}
              </article>
            </li>
          ))}
        </ol>
      </section>

      {resume.projects.length > 0 ? (
        <section class="resume-section" aria-labelledby="projects-title">
          <div class="section-heading">
            <span>02</span>
            <h2 id="projects-title">Projects</h2>
          </div>

          <div class="entry-list">
            {resume.projects.map((project) => (
              <article class="entry">
                <header>
                  <h3>{project.name}</h3>
                  {project.description ? <p class="meta">{project.description}</p> : null}
                </header>
                <ul>
                  {project.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </section>
      ) : null}

      {skillGroups.length > 0 ? (
        <section class="resume-section" aria-labelledby="skills-title">
          <div class="section-heading">
            <span>03</span>
            <h2 id="skills-title">Skills</h2>
          </div>

          <div class="skills-grid">
            {skillGroups.map(([group, items]) => (
              <section class="skill-group" aria-labelledby={`skill-${group}`}>
                <h3 id={`skill-${group}`}>{group}</h3>
                <p>{items.join(" / ")}</p>
              </section>
            ))}
          </div>
        </section>
      ) : null}

      <section class="resume-section" aria-labelledby="education-title">
        <div class="section-heading">
          <span>04</span>
          <h2 id="education-title">Education & Training</h2>
        </div>

        <div class="entry-list compact">
          {[...resume.training, ...resume.education].map((entry) => (
            <article class="entry">
              <header>
                <p class="period">{entry.period}</p>
                <h3>{entry.degree}</h3>
                <p class="meta">
                  {entry.institution}
                  {entry.location ? ` / ${entry.location}` : ""}
                </p>
              </header>
            </article>
          ))}
        </div>
      </section>

      {resume.languages.length > 0 ? (
        <section class="resume-section compact-final" aria-labelledby="languages-title">
          <div class="section-heading">
            <span>05</span>
            <h2 id="languages-title">Languages</h2>
          </div>
          <p class="language-line">
            {resume.languages.map((language) => `${language.name}: ${language.proficiency}`).join(" / ")}
          </p>
        </section>
      ) : null}
    </article>
  </main>

  <Footer {...footer} />
</Layout>

<style>
  .resume-shell {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: minmax(16rem, 22rem) minmax(0, 48rem);
    gap: clamp(var(--spacing-32), 6vw, var(--spacing-64));
    width: min(76rem, calc(100% - (2 * max(var(--spacing-16), 5vw))));
    margin: 0 auto;
    padding:
      clamp(var(--spacing-48), 8vh, var(--spacing-96))
      0
      calc(var(--spacing-96) + env(safe-area-inset-bottom, 0px));
  }

  .resume-rail {
    position: sticky;
    top: var(--spacing-48);
    align-self: start;
    min-width: 0;
    padding-top: var(--spacing-8);
  }

  .chapter-kicker,
  .period,
  .meta,
  .tags,
  dt {
    color: color-mix(in srgb, var(--colors-muted) 86%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  h1,
  .resume-header h2 {
    margin: var(--spacing-12) 0;
    color: var(--colors-fg);
    font-size: clamp(2.25rem, 7vw, 4.75rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: 0;
  }

  .headline {
    max-width: 22rem;
    margin: 0 0 var(--spacing-32);
    color: color-mix(in srgb, var(--colors-fg) 78%, transparent);
    font-size: 1rem;
    line-height: 1.5;
  }

  .contact-list {
    display: grid;
    gap: var(--spacing-16);
    margin: 0 0 var(--spacing-32);
  }

  .contact-list div {
    display: grid;
    gap: var(--spacing-4);
    padding-top: var(--spacing-12);
    border-top: 1px solid rgba(245, 245, 247, 0.08);
  }

  dd {
    display: grid;
    gap: var(--spacing-4);
    min-width: 0;
    color: color-mix(in srgb, var(--colors-fg) 82%, transparent);
    font-size: 0.875rem;
    line-height: 1.45;
  }

  a {
    color: var(--colors-fg);
    text-decoration-color: rgba(47, 107, 255, 0.5);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  a:hover,
  a:focus-visible {
    color: var(--colors-accent);
  }

  .resume-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }

  .action {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0 var(--spacing-16);
    border: 1px solid rgba(245, 245, 247, 0.12);
    color: var(--colors-fg);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .action--primary {
    border-color: color-mix(in srgb, var(--colors-accent) 58%, transparent);
    background: color-mix(in srgb, var(--colors-accent) 16%, transparent);
  }

  .resume-document {
    display: grid;
    gap: var(--spacing-64);
    min-width: 0;
  }

  .resume-header {
    padding-bottom: var(--spacing-32);
    border-bottom: 1px solid rgba(245, 245, 247, 0.1);
  }

  .resume-header p:last-child {
    max-width: 60rem;
    color: color-mix(in srgb, var(--colors-fg) 78%, transparent);
    font-size: 1rem;
    line-height: 1.75;
  }

  .resume-section {
    display: grid;
    gap: var(--spacing-24);
  }

  .section-heading {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-12);
    padding-bottom: var(--spacing-12);
    border-bottom: 1px solid rgba(245, 245, 247, 0.1);
  }

  .section-heading span {
    color: var(--colors-accent);
    font-size: 0.75rem;
    font-weight: 800;
  }

  .section-heading h2 {
    color: var(--colors-fg);
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .timeline,
  .entry-list {
    display: grid;
    gap: var(--spacing-24);
    list-style: none;
  }

  .entry {
    display: grid;
    gap: var(--spacing-12);
    min-width: 0;
  }

  .entry h3 {
    margin: var(--spacing-4) 0;
    color: var(--colors-fg);
    font-size: 1.125rem;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .entry ul {
    display: grid;
    gap: var(--spacing-8);
    padding-left: 1.15rem;
    color: color-mix(in srgb, var(--colors-fg) 78%, transparent);
    font-size: 0.875rem;
    line-height: 1.65;
  }

  .entry li::marker {
    color: var(--colors-accent);
  }

  .tags {
    color: color-mix(in srgb, var(--colors-warning) 78%, transparent);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-24);
  }

  .skill-group {
    display: grid;
    gap: var(--spacing-8);
    min-width: 0;
    padding-top: var(--spacing-12);
    border-top: 1px solid rgba(245, 245, 247, 0.08);
  }

  .skill-group h3 {
    color: var(--colors-fg);
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .skill-group p,
  .language-line {
    color: color-mix(in srgb, var(--colors-fg) 72%, transparent);
    font-size: 0.8125rem;
    line-height: 1.65;
  }

  .compact {
    gap: var(--spacing-16);
  }

  .compact-final {
    padding-bottom: var(--spacing-24);
  }

  @media (max-width: 860px) {
    .resume-shell {
      grid-template-columns: 1fr;
      gap: var(--spacing-48);
      width: min(42rem, calc(100% - (2 * var(--spacing-16))));
      padding-top: var(--spacing-48);
    }

    .resume-rail {
      position: static;
      padding-bottom: var(--spacing-32);
      border-bottom: 1px solid rgba(245, 245, 247, 0.1);
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }
  }

  @media print {
    :global(.grid-container),
    :global(.footer-container),
    :global(.skip-link) {
      display: none !important;
    }

    :global(body) {
      background: #fff;
      color: #000;
    }

    .resume-shell {
      display: block;
      width: auto;
      padding: 0;
    }

    .resume-rail {
      position: static;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid #aaa;
    }

    .resume-actions {
      display: none;
    }

    h1,
    .resume-header h2,
    .section-heading h2,
    .entry h3,
    .skill-group h3,
    .headline,
    .resume-header p:last-child,
    .entry ul,
    .skill-group p,
    .language-line,
    dd,
    a,
    .meta,
    .period,
    .tags,
    dt {
      color: #000;
    }

    h1,
    .resume-header h2 {
      font-size: 24pt;
    }

    .resume-document {
      gap: 1rem;
    }
  }
</style>
