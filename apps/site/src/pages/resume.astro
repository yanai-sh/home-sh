---
import Background from "@components/Background.astro";
import Footer from "@components/Footer.astro";
import ResumeDocument from "@components/ResumeDocument.astro";
import Layout from "@layouts/Layout.astro";
import { footerEdgeProps } from "@lib/footer-edge";
import { resumeSnapshotForPage } from "@lib/resume-page-snapshot";

const snapshot = resumeSnapshotForPage();
const resume = snapshot.data;
const source = snapshot.source;
const footer = footerEdgeProps(Astro.request);
const pageTitle = `${resume.header.name} — resume`;
const pageDescription = `${resume.header.name}, ${resume.header.headline}.`;
const sourceLabel = source.fallback ? "fallback snapshot" : "pinned resume submodule";
const sourceDetail = source.commitSha ? source.commitSha.slice(0, 7) : source.path;
---

<Layout title={pageTitle} description={pageDescription}>
  <Background />

  <main class="resume-shell" id="main-content" tabindex="-1">
    <aside class="resume-rail" aria-label="Resume summary">
      <p class="chapter-kicker">resume / source</p>
      <h1>{resume.header.name}</h1>
      <p class="headline">{resume.header.headline}</p>

      <dl class="contact-list">
        <div>
          <dt>email</dt>
          <dd><a href={`mailto:${resume.header.email}`}>{resume.header.email}</a></dd>
        </div>
        {resume.header.location ? (
          <div>
            <dt>location</dt>
            <dd>{resume.header.location}</dd>
          </div>
        ) : null}
        <div>
          <dt>source</dt>
          <dd>
            <a href={source.url}>{sourceLabel}</a>
            <span>{sourceDetail}</span>
          </dd>
        </div>
      </dl>

      <nav class="resume-actions" aria-label="Resume actions">
        <a class="action action--primary" href="/resume.pdf" download>Download PDF</a>
        <a class="action" href="/">Home</a>
      </nav>
    </aside>

    <ResumeDocument resume={resume} titleId="resume-title" />
  </main>

  <Footer {...footer} />
</Layout>

<style>
  .resume-shell {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: minmax(16rem, 22rem) minmax(0, 48rem);
    gap: clamp(var(--spacing-32), 6vw, var(--spacing-64));
    width: min(76rem, calc(100% - (2 * max(var(--spacing-16), 5vw))));
    margin: 0 auto;
    padding:
      clamp(var(--spacing-48), 8vh, var(--spacing-96))
      0
      calc(var(--spacing-96) + env(safe-area-inset-bottom, 0px));
  }

  .resume-rail {
    position: sticky;
    top: var(--spacing-48);
    align-self: start;
    min-width: 0;
    padding-top: var(--spacing-8);
  }

  .period,
  .meta,
  .tags,
  dt {
    color: color-mix(in srgb, var(--colors-muted) 86%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  h1 {
    margin: var(--spacing-12) 0;
    color: var(--colors-fg);
    font-size: clamp(2.25rem, 7vw, 4.75rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: 0;
  }

  .headline {
    max-width: 22rem;
    margin: 0 0 var(--spacing-32);
    color: color-mix(in srgb, var(--colors-fg) 78%, transparent);
    font-size: 1rem;
    line-height: 1.5;
  }

  .contact-list {
    display: grid;
    gap: var(--spacing-16);
    margin: 0 0 var(--spacing-32);
  }

  .contact-list div {
    display: grid;
    gap: var(--spacing-4);
    padding-top: var(--spacing-12);
    border-top: 1px solid rgba(245, 245, 247, 0.08);
  }

  dd {
    display: grid;
    gap: var(--spacing-4);
    min-width: 0;
    color: color-mix(in srgb, var(--colors-fg) 82%, transparent);
    font-size: 0.875rem;
    line-height: 1.45;
  }

  a {
    color: var(--colors-fg);
    text-decoration-color: rgba(47, 107, 255, 0.5);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  a:hover,
  a:focus-visible {
    color: var(--colors-accent);
  }

  .resume-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }

  .action {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0 var(--spacing-16);
    border: 1px solid rgba(245, 245, 247, 0.12);
    color: var(--colors-fg);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .action--primary {
    border-color: color-mix(in srgb, var(--colors-accent) 58%, transparent);
    background: color-mix(in srgb, var(--colors-accent) 16%, transparent);
  }

  @media (max-width: 860px) {
    .resume-shell {
      grid-template-columns: 1fr;
      gap: var(--spacing-48);
      width: min(42rem, calc(100% - (2 * var(--spacing-16))));
      padding-top: var(--spacing-48);
    }

    .resume-rail {
      position: static;
      padding-bottom: var(--spacing-32);
      border-bottom: 1px solid rgba(245, 245, 247, 0.1);
    }
  }

  @media print {
    :global(.grid-container),
    :global(.footer-container),
    :global(.skip-link) {
      display: none !important;
    }

    :global(body) {
      background: #fff;
      color: #000;
    }

    .resume-shell {
      display: block;
      width: auto;
      padding: 0;
    }

    .resume-rail {
      position: static;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid #aaa;
    }

    .resume-actions {
      display: none;
    }

    h1,
    .headline,
    dd,
    a,
    .meta,
    .period,
    dt {
      color: #000;
    }

    h1 {
      font-size: 24pt;
    }
  }
</style>
