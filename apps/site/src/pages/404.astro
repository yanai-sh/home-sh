---
import { SITE_TITLE } from '@config/site';
import Layout from '../layouts/Layout.astro';

Astro.response.status = 404;
const title = `Page not found — ${SITE_TITLE}`;
---

<Layout title={title}>
  <section class="section-container py-24 text-center">
    <h1 class="font-heading text-4xl font-bold text-maintext">404</h1>
    <p class="text-subtext font-body mt-4 max-w-md mx-auto">
      This URL is not part of the site. Use the link below to return home.
    </p>
    <a
      href="/"
      class="mt-10 inline-block rounded-full border border-accent/30 bg-accent/10 px-8 py-2 font-body text-maintext transition-colors hover:border-accent/50"
    >
      Back to {SITE_TITLE}
    </a>
  </section>
</Layout>
