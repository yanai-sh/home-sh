---
import { Icon } from 'astro-icon/components';
import { portfolio } from '../data/portfolio';

const { hero, resumeLabel, resumeUrl, socials } = portfolio;
---

<section id={hero.id} class="hero-section" aria-labelledby={hero.titleId} data-systems-hero>
  <div class="hero-field" aria-hidden="true"></div>

  <div class="hero-copy">
    <p class="section-eyebrow">{hero.eyebrow}</p>
    <h1 id={hero.titleId}>{hero.headline}</h1>
    <p class="hero-role">{hero.byline}</p>
    <p class="hero-lede">{hero.lede}</p>

    <div class="hero-actions" aria-label={hero.actionsLabel}>
      {hero.actions.map((action, index) => (
        <a class={`button-link ${index === 0 ? 'button-link--primary' : ''}`} href={action.href}>{action.label}</a>
      ))}
      <a class="button-link" href={resumeUrl} target="_blank" rel="noopener noreferrer">{resumeLabel}</a>
    </div>
  </div>

  <aside class="hero-focus panel" aria-label={hero.focus.label}>
    <div class="hero-focus__header">
      <p class="hero-focus__label">{hero.focus.eyebrow}</p>
      <span>01 / focus</span>
    </div>

    <div class="hero-focus__core">
      <span class="hero-focus__mark" aria-hidden="true"></span>
      <h2>{hero.focus.title}</h2>
    </div>

    <p class="hero-focus__summary">{hero.focus.summary}</p>

    <ul class="hero-focus__items" aria-label="Focus areas">
      {hero.focus.items.map((item) => <li>{item}</li>)}
    </ul>

    <div class="hero-socials" aria-label="Social links">
      {socials.filter((social) => social.url).map((social) => (
        <a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.name}>
          <Icon name={social.icon} />
          <span>{social.name}</span>
        </a>
      ))}
    </div>
  </aside>
</section>

<style>
  .hero-section {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 26rem);
    gap: 4rem;
    align-items: end;
    min-height: calc(100svh - 6rem);
    padding: 7rem 0 4rem;
  }

  .hero-field {
    position: absolute;
    inset: 0 calc((100vw - 100%) / -2);
    z-index: -2;
    overflow: hidden;
    background:
      radial-gradient(circle at 22% 28%, rgba(47, 107, 255, 0.16), transparent 30rem),
      radial-gradient(circle at 74% 42%, rgba(118, 255, 213, 0.08), transparent 26rem),
      linear-gradient(135deg, rgba(120, 164, 255, 0.1) 0 1px, transparent 1px 11rem);
    background-size:
      auto,
      auto,
      11rem 11rem;
  }

  [data-theme="light"] .hero-field {
    background:
      radial-gradient(circle at 24% 25%, rgba(31, 95, 255, 0.14), transparent 27rem),
      radial-gradient(circle at 80% 36%, rgba(0, 126, 118, 0.1), transparent 24rem),
      linear-gradient(135deg, rgba(23, 79, 199, 0.12) 0 1px, transparent 1px 10rem);
    background-size:
      auto,
      auto,
      10rem 10rem;
  }

  .hero-field::before,
  .hero-field::after {
    position: absolute;
    inset: 0;
    content: "";
    pointer-events: none;
  }

  .hero-field::before {
    background:
      linear-gradient(100deg, transparent 0 16%, rgba(255, 205, 118, 0.13) 16.2%, transparent 16.8% 54%, rgba(120, 164, 255, 0.12) 54.2%, transparent 55%),
      repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.018) 0 1px, transparent 1px 7px);
    mix-blend-mode: screen;
    opacity: 0.5;
  }

  [data-theme="light"] .hero-field::before {
    background:
      linear-gradient(100deg, transparent 0 18%, rgba(145, 82, 18, 0.1) 18.2%, transparent 18.9% 58%, rgba(23, 79, 199, 0.11) 58.2%, transparent 59%),
      repeating-linear-gradient(0deg, rgba(16, 22, 29, 0.025) 0 1px, transparent 1px 8px);
    mix-blend-mode: multiply;
    opacity: 0.62;
  }

  .hero-field::after {
    background:
      linear-gradient(90deg, var(--color-background) 0%, transparent 14%, transparent 78%, var(--color-background) 100%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-background) 34%, transparent) 0%, transparent 24%, transparent 68%, var(--color-background) 100%);
  }

  [data-theme="light"] .hero-field::after {
    background:
      linear-gradient(90deg, var(--color-background) 0%, rgba(251, 252, 248, 0.08) 18%, rgba(251, 252, 248, 0.04) 74%, var(--color-background) 100%),
      linear-gradient(180deg, rgba(251, 252, 248, 0.24) 0%, transparent 24%, transparent 62%, var(--color-background) 100%);
  }

  .hero-copy,
  .hero-focus {
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 46rem;
  }

  h1 {
    margin: 0;
    color: var(--color-maintext);
    font-family: var(--font-heading);
    font-size: 6.4rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.92;
    text-wrap: balance;
  }

  .hero-lede {
    max-width: 44rem;
    margin: 2rem 0 0;
    color: color-mix(in srgb, var(--color-maintext) 82%, transparent);
    font-size: 1.15rem;
    line-height: 1.62;
  }

  .hero-role {
    margin: 1rem 0 0;
    color: color-mix(in srgb, var(--color-accent-text) 84%, var(--color-maintext));
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hero-focus {
    display: grid;
    gap: 1.2rem;
    padding: clamp(1.25rem, 3vw, 1.6rem);
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--color-accent) 12%, transparent), transparent 44%),
      color-mix(in srgb, var(--color-surface) 72%, transparent);
    backdrop-filter: blur(18px);
  }

  [data-theme="light"] .hero-focus {
    border-color: rgba(21, 27, 34, 0.16);
    background:
      linear-gradient(145deg, rgba(28, 86, 214, 0.1), transparent 48%),
      color-mix(in srgb, var(--color-surface) 84%, transparent);
    box-shadow:
      0 26px 58px rgba(38, 55, 78, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .hero-focus__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-focus__header span {
    white-space: nowrap;
  }

  .hero-focus__label {
    margin: 0;
    color: var(--color-accent-text);
    font-weight: 800;
  }

  .hero-focus__core {
    display: grid;
    gap: 0.75rem;
    min-height: 5rem;
    border-block: 1px solid var(--color-rule);
    padding-block: 1rem;
  }

  .hero-focus__mark {
    position: relative;
    width: 3.4rem;
    height: 0.32rem;
    border-radius: 999px;
    background:
      linear-gradient(90deg, var(--color-accent), color-mix(in srgb, #007e76 76%, var(--color-accent)));
    box-shadow: 0 0 0 0.42rem color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .hero-focus__mark::after {
    position: absolute;
    top: 50%;
    right: -1.45rem;
    width: 0.54rem;
    height: 0.54rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 42%, transparent);
    border-radius: 999px;
    content: "";
    transform: translateY(-50%);
  }

  .hero-focus h2 {
    margin: 0;
    color: var(--color-maintext);
    font-family: var(--font-heading);
    font-size: clamp(1.45rem, 2.6vw, 2.05rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.04;
    text-wrap: balance;
  }

  .hero-focus__summary {
    margin: 0;
    color: var(--color-subtext);
    font-size: 0.96rem;
    line-height: 1.62;
  }

  .hero-focus__items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-focus__items li {
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    padding: 0.42rem 0.62rem;
    color: color-mix(in srgb, var(--color-maintext) 88%, transparent);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1;
    text-transform: uppercase;
  }

  .hero-socials {
    display: grid;
    gap: 0.5rem;
    padding-top: 0.4rem;
  }

  .hero-socials a {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-subtext);
    font-size: 0.86rem;
    font-weight: 750;
    text-decoration: none;
  }

  .hero-socials a:hover {
    color: var(--color-maintext);
  }

  .hero-socials :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
  }

  @media (max-width: 900px) {
    .hero-section {
      grid-template-columns: 1fr;
      align-items: start;
      min-height: auto;
    }

    .hero-focus {
      max-width: 36rem;
    }
  }

  @media (max-width: 720px) {
    .hero-section {
      padding-top: 3.2rem;
      padding-bottom: 2.5rem;
    }

    .hero-field {
      opacity: 0.72;
    }

    h1 {
      font-size: 4rem;
    }
  }

  @media (max-width: 480px) {
    h1 {
      font-size: 3.2rem;
    }
  }

</style>
