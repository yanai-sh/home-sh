---
import { Icon } from 'astro-icon/components';
import { portfolio } from '../data/portfolio';

const { hero, resumeLabel, resumeUrl, socials } = portfolio;
---

<section id={hero.id} class="hero-section" aria-labelledby={hero.titleId} data-systems-hero>
  <div class="hero-field" aria-hidden="true"></div>

  <div class="hero-copy">
    <p class="section-eyebrow">{hero.eyebrow}</p>
    <h1 id={hero.titleId}>{hero.headline}</h1>
    <p class="hero-role">{hero.byline}</p>
    <p class="hero-lede">{hero.lede}</p>

    <div class="hero-actions" aria-label={hero.actionsLabel}>
      {hero.actions.map((action, index) => (
        <a class={`button-link ${index === 0 ? 'button-link--primary' : ''}`} href={action.href}>{action.label}</a>
      ))}
      <a class="button-link" href={resumeUrl} target="_blank" rel="noopener noreferrer">{resumeLabel}</a>
    </div>
  </div>

  <aside class="hero-artifact panel" aria-label={hero.artifact.label}>
    <div class="hero-artifact__header">
      <p class="hero-artifact__label">{hero.artifact.eyebrow}</p>
      <span>01 / hero</span>
    </div>

    <div class="hero-artifact__core" aria-hidden="true">
      <span class="hero-artifact__pulse"></span>
      <h2>{hero.artifact.title}</h2>
    </div>

    <dl class="hero-artifact__readout">
      {hero.artifact.rows.map((row) => (
        <div>
          <dt>{row.label}</dt>
          <dd>{row.value}</dd>
        </div>
      ))}
    </dl>

    <div class="hero-socials" aria-label="Social links">
      {socials.filter((social) => social.url).map((social) => (
        <a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.name}>
          <Icon name={social.icon} />
          <span>{social.name}</span>
        </a>
      ))}
    </div>
  </aside>
</section>

<style>
  .hero-section {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 26rem);
    gap: 4rem;
    align-items: end;
    min-height: calc(100svh - 6rem);
    padding: 7rem 0 4rem;
  }

  .hero-field {
    position: absolute;
    inset: 0 calc((100vw - 100%) / -2);
    z-index: -2;
    overflow: hidden;
    background:
      radial-gradient(circle at 26% 28%, rgba(47, 107, 255, 0.2), transparent 28rem),
      radial-gradient(circle at 74% 40%, rgba(118, 255, 213, 0.11), transparent 24rem),
      linear-gradient(135deg, rgba(120, 164, 255, 0.12) 0 1px, transparent 1px 11rem),
      linear-gradient(90deg, rgba(245, 247, 250, 0.06) 1px, transparent 1px),
      linear-gradient(180deg, rgba(245, 247, 250, 0.045) 1px, transparent 1px),
      #090e14;
    background-size:
      auto,
      auto,
      11rem 11rem,
      4.5rem 4.5rem,
      4.5rem 4.5rem,
      auto;
  }

  [data-theme="light"] .hero-field {
    background:
      radial-gradient(circle at 24% 26%, rgba(47, 107, 255, 0.16), transparent 25rem),
      radial-gradient(circle at 78% 38%, rgba(0, 126, 118, 0.11), transparent 23rem),
      linear-gradient(135deg, rgba(36, 91, 220, 0.16) 0 1px, transparent 1px 10rem),
      linear-gradient(90deg, rgba(21, 27, 34, 0.08) 1px, transparent 1px),
      linear-gradient(180deg, rgba(21, 27, 34, 0.06) 1px, transparent 1px),
      #f7faff;
    background-size:
      auto,
      auto,
      10rem 10rem,
      4.25rem 4.25rem,
      4.25rem 4.25rem,
      auto;
  }

  .hero-field::before,
  .hero-field::after {
    position: absolute;
    inset: 0;
    content: "";
    pointer-events: none;
  }

  .hero-field::before {
    background:
      linear-gradient(100deg, transparent 0 16%, rgba(255, 205, 118, 0.18) 16.2%, transparent 16.8% 54%, rgba(120, 164, 255, 0.18) 54.2%, transparent 55%),
      repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.028) 0 1px, transparent 1px 7px);
    mix-blend-mode: screen;
    opacity: 0.55;
  }

  [data-theme="light"] .hero-field::before {
    background:
      linear-gradient(100deg, transparent 0 18%, rgba(179, 104, 22, 0.14) 18.2%, transparent 18.9% 58%, rgba(36, 91, 220, 0.14) 58.2%, transparent 59%),
      repeating-linear-gradient(0deg, rgba(21, 27, 34, 0.035) 0 1px, transparent 1px 8px);
    mix-blend-mode: multiply;
    opacity: 0.78;
  }

  .hero-field::after {
    background:
      linear-gradient(90deg, var(--color-background) 0%, transparent 18%, transparent 72%, var(--color-background) 100%),
      linear-gradient(180deg, transparent 0%, transparent 62%, var(--color-background) 100%);
  }

  [data-theme="light"] .hero-field::after {
    background:
      linear-gradient(90deg, var(--color-background) 0%, rgba(245, 247, 250, 0.22) 20%, rgba(245, 247, 250, 0.12) 70%, var(--color-background) 100%),
      linear-gradient(180deg, transparent 0%, transparent 58%, var(--color-background) 100%);
  }

  .hero-copy,
  .hero-artifact {
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 46rem;
  }

  h1 {
    margin: 0;
    color: var(--color-maintext);
    font-family: var(--font-heading);
    font-size: 6.4rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.92;
    text-wrap: balance;
  }

  .hero-lede {
    max-width: 44rem;
    margin: 2rem 0 0;
    color: color-mix(in srgb, var(--color-maintext) 82%, transparent);
    font-size: 1.15rem;
    line-height: 1.62;
  }

  .hero-role {
    margin: 1rem 0 0;
    color: color-mix(in srgb, var(--color-accent-text) 84%, var(--color-maintext));
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hero-artifact {
    display: grid;
    gap: 1.15rem;
    padding: clamp(1.25rem, 3vw, 1.6rem);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 10%, transparent), transparent 42%),
      color-mix(in srgb, var(--color-surface) 68%, transparent);
    backdrop-filter: blur(18px);
  }

  [data-theme="light"] .hero-artifact {
    border-color: rgba(21, 27, 34, 0.16);
    background:
      linear-gradient(135deg, rgba(36, 91, 220, 0.08), transparent 46%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(247, 250, 255, 0.72)),
      color-mix(in srgb, var(--color-surface) 78%, transparent);
    box-shadow:
      0 26px 60px rgba(45, 68, 102, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.82);
  }

  .hero-artifact__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-artifact__header span {
    white-space: nowrap;
  }

  .hero-artifact__label {
    margin: 0;
    color: var(--color-accent-text);
    font-weight: 800;
  }

  .hero-artifact__core {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: center;
    min-height: 4rem;
    border-block: 1px solid var(--color-rule);
    padding-block: 1rem;
  }

  .hero-artifact__pulse {
    position: relative;
    width: 0.78rem;
    height: 0.78rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 0.48rem color-mix(in srgb, var(--color-accent) 14%, transparent);
  }

  .hero-artifact__pulse::after {
    position: absolute;
    inset: -0.68rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 34%, transparent);
    border-radius: inherit;
    content: "";
  }

  .hero-artifact h2 {
    margin: 0;
    color: var(--color-maintext);
    font-family: var(--font-mono);
    font-size: clamp(1.25rem, 2.4vw, 1.75rem);
    font-weight: 750;
    letter-spacing: 0;
    line-height: 1;
  }

  .hero-artifact__readout {
    display: grid;
    gap: 0.7rem;
    margin: 0;
  }

  .hero-artifact__readout div {
    display: grid;
    grid-template-columns: minmax(5.25rem, auto) 1fr;
    gap: 1rem;
    align-items: baseline;
  }

  .hero-artifact__readout dt {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-artifact__readout dd {
    margin: 0;
    color: var(--color-maintext);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .hero-socials {
    display: grid;
    gap: 0.5rem;
    padding-top: 0.4rem;
  }

  .hero-socials a {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-subtext);
    font-size: 0.86rem;
    font-weight: 750;
    text-decoration: none;
  }

  .hero-socials a:hover {
    color: var(--color-maintext);
  }

  .hero-socials :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
  }

  @media (max-width: 900px) {
    .hero-section {
      grid-template-columns: 1fr;
      align-items: start;
      min-height: auto;
    }

    .hero-artifact {
      max-width: 36rem;
    }
  }

  @media (max-width: 720px) {
    .hero-section {
      padding-top: 3.2rem;
      padding-bottom: 2.5rem;
    }

    .hero-field {
      opacity: 0.72;
    }

    h1 {
      font-size: 4rem;
    }
  }

  @media (max-width: 480px) {
    h1 {
      font-size: 3.2rem;
    }
  }

</style>
