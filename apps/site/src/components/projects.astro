---
import { getCollection } from 'astro:content';
import { featuredHomepageProjects } from '@lib/portfolio-content';
import { portfolio } from '../data/portfolio';
import ProjectCard from './project-card.astro';

const { projects } = portfolio;
const featuredProjects = featuredHomepageProjects(await getCollection('projects'));
---

<section id={projects.id} class="section-block projects-section" aria-labelledby={projects.titleId}>
  <header class="section-header">
    <p class="section-eyebrow">{projects.eyebrow}</p>
    <h2 id={projects.titleId} class="section-title">{projects.title}</h2>
    <p class="section-deck">{projects.deck}</p>
  </header>

  <div class={`projects-grid ${featuredProjects.length === 1 ? 'projects-grid--single' : ''}`}>
    {featuredProjects.map((project, index) => <ProjectCard project={project.data} index={index} labels={projects.card} />)}
  </div>
</section>

<style>
  .projects-section {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
  }

  .section-header {
    max-width: 50rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .projects-grid--single {
    max-width: 38rem;
  }

  @media (max-width: 760px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
