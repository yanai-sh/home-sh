---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'experience'>['data'];
  skillLabelSuffix: string;
}

const { item, skillLabelSuffix } = Astro.props;
---

<article class="career-card">
  <div class="career-card__meta">
    <p>{item.period}</p>
    <span>{item.company}</span>
  </div>
  <div class="career-card__body">
    <h3>{item.role}</h3>
    {item.scope ? <p class="career-card__type">{item.scope}</p> : null}
    <p class="career-card__description">{item.description}</p>
    <div class="career-card__skills" aria-label={`${item.role} ${skillLabelSuffix}`}>
      {item.skillGroups.map((group) => (
        <section class="career-card__skill-group" aria-label={`${group.label} ${skillLabelSuffix}`}>
          <h4>{group.label}</h4>
          <ul class="chip-row">
            {group.skills.map((skill) => <li class="chip">{skill}</li>)}
          </ul>
        </section>
      ))}
    </div>
  </div>
</article>

<style>
  .career-card {
    display: grid;
    grid-template-columns: 12rem minmax(0, 1fr);
    gap: clamp(1rem, 4vw, 2.5rem);
    padding: 1.35rem 0;
    border-top: 1px solid var(--color-rule);
  }

  .career-card:first-child {
    border-top: none;
    padding-top: 0;
  }

  .career-card__meta p,
  .career-card__meta span,
  .career-card__body h3,
  .career-card__type,
  .career-card__description {
    margin: 0;
  }

  .career-card__meta p {
    color: var(--color-accent-text);
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .career-card__meta span {
    display: block;
    margin-top: 0.35rem;
    color: var(--color-muted);
    font-size: 0.82rem;
    font-weight: 750;
  }

  .career-card__body {
    min-width: 0;
  }

  .career-card__body h3 {
    color: var(--color-maintext);
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.05;
  }

  .career-card__type {
    margin-top: 0.45rem;
    color: var(--color-subtext);
    font-size: 0.92rem;
    font-weight: 750;
    line-height: 1.35;
  }

  .career-card__description {
    margin-top: 0.8rem;
    color: color-mix(in srgb, var(--color-maintext) 76%, transparent);
    line-height: 1.65;
  }

  .career-card__skills {
    display: grid;
    gap: 0.85rem;
    margin-top: 1rem;
  }

  .career-card__skill-group {
    display: grid;
    gap: 0.45rem;
    align-content: start;
  }

  .career-card__skill-group h4 {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.16em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .career-card__skill-group .chip-row {
    margin-top: 0;
  }

  @media (min-width: 900px) {
    .career-card__skills {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .career-card {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }
</style>
