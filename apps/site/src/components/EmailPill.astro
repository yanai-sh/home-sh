---
import { SITE_EMAIL } from "@config/site";
---

<div class="email-block">
  <span id="copy-live" class="sr-only" aria-live="polite" aria-atomic="true"></span>
  <button
    type="button"
    class="glass-pill"
    id="copy-email"
    data-email={SITE_EMAIL}
    data-default-aria={`Copy ${SITE_EMAIL}`}
    aria-label={`Copy ${SITE_EMAIL}`}
  >
    <span class="pill-text">{SITE_EMAIL}</span>
    <span class="copy-glyph" aria-hidden="true">
      <svg class="copy-svg copy-icon" viewBox="0 0 24 24" width="22" height="22" focusable="false">
        <rect
          x="9"
          y="9"
          width="13"
          height="13"
          rx="2"
          ry="2"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"></rect>
        <path
          d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linejoin="round"></path>
      </svg>
      <svg class="check-svg check-icon" viewBox="0 0 24 24" width="22" height="22" focusable="false">
        <path
          d="M20 6 9 17l-5-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2.25"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </span>
  </button>
</div>

<style>
  .email-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
  }

  .glass-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    min-height: 52px;
    max-width: 100%;
    min-width: 0;
    padding: 0.5rem 0.85rem 0.5rem 1rem;
    border-radius: 9999px;
    background: var(--colors-surface-base);
    border: 1px solid rgba(54, 60, 72, 1);
    backdrop-filter: blur(12px);
    cursor: pointer;
    font: inherit;
    color: var(--colors-fg);
    text-align: inherit;
    appearance: none;
    -webkit-appearance: none;
    transition:
      background 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease,
      transform 0.22s ease;
  }

  .glass-pill:hover {
    background: rgba(245, 245, 247, 0.06);
    border-color: rgba(47, 107, 255, 0.35);
  }

  .glass-pill:focus-visible {
    outline: 1px dashed rgba(47, 107, 255, 0.6);
    outline-offset: 3px;
  }

  .glass-pill.is-copied {
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.48);
    box-shadow: 0 0 0 1px rgba(16, 185, 129, 0.32), 0 0 26px rgba(16, 185, 129, 0.18);
  }

  .pill-text {
    color: var(--colors-fg);
    font-family: var(--fonts-mono);
    font-size: clamp(0.875rem, 0.8rem + 0.35vi, 1.0625rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: none;
    font-variant-numeric: tabular-nums;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s ease;
  }

  .glass-pill.is-copied .pill-text {
    color: #10b981;
    text-shadow: 0 0 18px rgba(16, 185, 129, 0.22);
  }

  .copy-glyph {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: var(--colors-muted);
    opacity: 0.42;
    transition:
      opacity 0.2s ease,
      color 0.2s ease;
  }

  .copy-icon,
  .check-icon {
    position: absolute;
    inset: 0;
    margin: auto;
    display: block;
    transition:
      opacity 0.22s ease,
      transform 0.26s cubic-bezier(0.34, 1.35, 0.64, 1);
  }

  .check-icon {
    opacity: 0;
    transform: scale(0.5) rotate(-12deg);
    color: #10b981;
  }

  .glass-pill.is-copied .copy-glyph {
    opacity: 1;
  }

  .glass-pill.is-copied .copy-icon {
    opacity: 0;
    transform: scale(0.65);
  }

  .glass-pill.is-copied .check-icon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .glass-pill:hover .copy-glyph,
  .glass-pill:focus-visible .copy-glyph {
    opacity: 1;
    color: #2F6BFF;
  }

  .glass-pill.is-copied .copy-glyph {
    color: #10b981;
  }

  .glass-pill.is-copied:hover .copy-glyph,
  .glass-pill.is-copied:focus-visible .copy-glyph {
    color: #10b981;
  }

  @keyframes email-copy-pop {
    0% {
      transform: scale(1);
    }
    45% {
      transform: scale(1.045);
    }
    100% {
      transform: scale(1);
    }
  }

  .glass-pill.is-copied {
    animation: email-copy-pop 0.42s cubic-bezier(0.34, 1.4, 0.64, 1);
  }

  @media (hover: none) {
    .copy-glyph {
      opacity: 0.62;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pill-text,
    .glass-pill.is-copied .pill-text {
      text-shadow: none;
    }

    .glass-pill.is-copied {
      animation: none;
    }

    .copy-icon,
    .check-icon {
      transition: opacity 0.15s ease;
    }

    .check-icon {
      transform: none;
    }

    .glass-pill.is-copied .copy-icon {
      transform: none;
    }
  }
</style>

<script>
  import { mountEmailPill } from "@lib/email-pill-client";

  mountEmailPill();
</script>
