<canvas class="scene-canvas" id="scene-canvas" aria-hidden="true"></canvas>

<style>
  .scene-canvas {
    position: fixed;
    inset: 0;
    z-index: 4;
    display: block;
    width: 100vw;
    height: 100dvh;
    pointer-events: none;
    opacity: 0;
    mix-blend-mode: screen;
    transition: opacity 0.28s ease;
  }

  :global(html.has-scroll-scene) .scene-canvas {
    opacity: 0.72;
  }

  @media (prefers-reduced-motion: reduce) {
    .scene-canvas {
      display: none;
    }
  }
</style>

<script>
  const sceneQuery = globalThis.matchMedia?.("(min-width: 900px) and (min-height: 520px)");
  const reduceMotionQuery = globalThis.matchMedia?.("(prefers-reduced-motion: reduce)");
  let imported = false;

  const canImportScene = () => (
    (sceneQuery?.matches ?? false) &&
    !(reduceMotionQuery?.matches ?? false)
  );

  const startScene = () => {
    if (imported || !canImportScene()) return;
    imported = true;

    import("@lib/scroll-scene-client").then(({ mountScrollScene }) => {
      mountScrollScene();
    }).catch(() => {
      imported = false;
    });
  };

  sceneQuery?.addEventListener("change", startScene);
  reduceMotionQuery?.addEventListener("change", startScene);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", startScene, { once: true });
  } else {
    startScene();
  }
</script>
