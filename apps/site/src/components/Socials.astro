---
/**
 * Hero socials row: profile links + click-to-copy email.
 * Hover/focus pattern (scale + accent color + revealed label) is borrowed from
 * nbakh16/career-portfolio-template's home.astro social row.
 */
import EmailIcon from "@components/icons/EmailIcon.astro";
import GithubIcon from "@components/icons/GithubIcon.astro";
import LinkedinIcon from "@components/icons/LinkedinIcon.astro";
import { SITE_EMAIL } from "@config/site";
import { SOCIAL } from "@config/social";
---

<nav class="socials" aria-label="Profiles and contact">
  <span id="socials-copy-live" class="sr-only" aria-live="polite" aria-atomic="true"></span>

  <a
    class="social"
    href={SOCIAL.github.href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={SOCIAL.github.label}
  >
    <GithubIcon class="icon" />
    <span class="social-label" aria-hidden="true">{SOCIAL.github.label}</span>
  </a>

  <a
    class="social"
    href={SOCIAL.linkedin.href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={SOCIAL.linkedin.label}
  >
    <LinkedinIcon class="icon" />
    <span class="social-label" aria-hidden="true">{SOCIAL.linkedin.label}</span>
  </a>

  <button
    type="button"
    class="social social--copy"
    id="copy-email"
    data-email={SITE_EMAIL}
    data-default-aria={`Copy email address ${SITE_EMAIL}`}
    aria-label={`Copy email address ${SITE_EMAIL}`}
  >
    <EmailIcon class="icon" />
    <span class="social-label" aria-hidden="true" data-state="default">Email</span>
    <span class="social-label social-label--copied" aria-hidden="true" data-state="copied">Copied!</span>
  </button>
</nav>

<style>
  .socials {
    position: relative;
    z-index: 20;
    display: flex;
    gap: clamp(1.4rem, 3vi, 2.4rem);
    align-items: flex-start;
    justify-content: center;
    padding-top: var(--spacing-16);
  }

  .social {
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 52px;
    min-height: 52px;
    padding: 0;
    background: none;
    border: none;
    color: color-mix(in srgb, var(--colors-fg) 78%, transparent);
    text-decoration: none;
    cursor: pointer;
    font: inherit;
    transition:
      color 0.25s ease,
      transform 0.25s ease;
  }

  .social :global(.icon),
  .social :global(svg) {
    width: clamp(1.85rem, 1.4rem + 1.4vi, 2.3rem);
    height: clamp(1.85rem, 1.4rem + 1.4vi, 2.3rem);
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .social-label {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 50%;
    color: var(--colors-accent);
    font-family: var(--fonts-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1.2;
    text-transform: uppercase;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transform: translate(-50%, -0.1rem) scale(0.85);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }

  .social-label--copied {
    color: #10b981;
  }

  .social[data-copied="true"] .social-label[data-state="default"] {
    opacity: 0;
  }

  .social[data-copied="true"] .social-label[data-state="copied"],
  .social:hover .social-label[data-state="default"],
  .social:focus-visible .social-label[data-state="default"] {
    opacity: 1;
    transform: translate(-50%, 0) scale(1);
  }

  .social:hover,
  .social:focus-visible {
    color: var(--colors-accent);
    transform: translateY(-0.12rem) scale(1.08);
  }

  .social[data-copied="true"] {
    color: #10b981;
  }

  .social:focus-visible {
    outline: 1px dashed color-mix(in srgb, var(--colors-accent) 70%, transparent);
    outline-offset: 0.4rem;
    border-radius: 999px;
  }

  @media (hover: none) {
    /* Touch devices: keep the labels visible so taps are unambiguous. */
    .social-label[data-state="default"] {
      opacity: 0.85;
      transform: translate(-50%, 0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .social,
    .social :global(.icon),
    .social :global(svg),
    .social-label {
      transition: opacity 0.15s ease;
      transform: none;
    }

    .social:hover,
    .social:focus-visible {
      transform: none;
    }
  }
</style>

<script>
  import { mountSocialsCopy } from "@lib/socials-client";

  mountSocialsCopy();
</script>
