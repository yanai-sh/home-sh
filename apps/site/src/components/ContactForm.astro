---
import { SITE_EMAIL } from "@config/site";
import { heroCta } from "../../styled-system/recipes";

const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const ctaPrimary = heroCta({ variant: "primary" });
const ctaOutline = heroCta({ variant: "outline" });
---

<section class="contact-section" id="contact" data-bg-variant="contact" aria-labelledby="contact-heading">
  <div class="contact-stage">
    <div class="contact-label">
      <h2 class="section-heading section-heading--display" id="contact-heading">
        <span aria-hidden="true" class="slash">/</span> Contact
      </h2>
      <p class="section-deck">
        Field engineering, integration work, or a chat — send the role and timeline.
      </p>

      <div class="contact-actions" aria-label="Contact actions">
        <a class={ctaPrimary} href={`mailto:${SITE_EMAIL}`}>Email me</a>
        <a class={ctaOutline} href="/resume.pdf" target="_blank" rel="noopener noreferrer">Download resume PDF</a>
      </div>
    </div>

    {siteKey ? (
      <form
        class="contact-form"
        id="contact-form"
        novalidate
        aria-label="Contact form"
        aria-describedby="cf-status"
        data-sitekey={siteKey}
      >
        <div class="form-field">
          <label class="form-label" for="cf-name">name</label>
          <input
            class="form-input"
            type="text"
            id="cf-name"
            name="name"
            autocomplete="name"
            required
            maxlength="100"
            placeholder="your name"
          />
        </div>

        <div class="form-field">
          <label class="form-label" for="cf-email">email</label>
          <input
            class="form-input"
            type="email"
            id="cf-email"
            name="email"
            autocomplete="email"
            required
            maxlength="254"
            placeholder="you@example.com"
          />
        </div>

        <div class="form-field">
          <label class="form-label" for="cf-message">message</label>
          <textarea
            class="form-input form-textarea"
            id="cf-message"
            name="message"
            required
            maxlength="2000"
            rows="5"
            placeholder="..."></textarea>
        </div>

        <div class="hp-trap" aria-hidden="true">
          <label for="cf-website">Website (leave blank)</label>
          <input
            type="text"
            name="website"
            id="cf-website"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <div class="form-turnstile" id="cf-turnstile-widget"></div>

        <div class="form-footer">
          <button class="form-submit" type="submit" id="cf-submit" disabled>
            send
          </button>
          <span class="form-status" id="cf-status" role="status" aria-live="polite"></span>
        </div>
      </form>
    ) : (
      <div class="contact-form contact-direct" aria-label="Direct contact">
        <p>
          Send the role, timeline, and where field engineering would help.
        </p>
      </div>
    )}
  </div>
</section>

<style>
  .contact-section {
    width: 100%;
    min-height: 100dvh;
    display: grid;
    align-items: center;
    position: relative;
    overflow: clip;
    padding:
      clamp(var(--spacing-48), 8vh, var(--spacing-96))
      max(var(--spacing-16), min(var(--spacing-48), 5vi))
      calc(clamp(var(--spacing-48), 9vh, var(--spacing-96)) + env(safe-area-inset-bottom, 0px));
    box-sizing: border-box;
    transform-style: preserve-3d;
  }

  .contact-stage {
    position: relative;
    width: min(74rem, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(22rem, 0.78fr);
    gap: clamp(var(--spacing-32), 7vi, var(--spacing-96));
    align-items: start;
    z-index: 1;
  }

  :global(html.has-scroll-scene) .contact-stage {
    position: fixed;
    /* Anchor above mid-viewport so the form + heading read as one unit, not “bottom heavy”. */
    top: 26%;
    left: max(var(--spacing-16), min(var(--spacing-48), 5vi));
    right: max(var(--spacing-16), min(var(--spacing-48), 5vi));
    z-index: 11;
    width: min(
      74rem,
      calc(
        100vw - max(var(--spacing-16), min(var(--spacing-48), 5vi)) -
          max(var(--spacing-16), min(var(--spacing-48), 5vi))
      )
    );
    transform-origin: 50% 8%;
    will-change: transform, opacity;
  }

  .contact-label {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
    min-width: 0;
  }

  .contact-label .contact-actions {
    margin-top: var(--spacing-8);
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-12);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
    width: 100%;
    min-width: 0;
    padding: clamp(var(--spacing-16), 3vi, var(--spacing-32));
    border: 1px solid rgba(245, 245, 247, 0.16);
    border-radius: 8px;
    background:
      linear-gradient(180deg, var(--colors-surface-contact-lift), rgba(245, 247, 250, 0.1)),
      var(--colors-surface-contact);
    color: rgba(245, 247, 250, 0.94);
    box-shadow:
      0 0 0 1px rgba(47, 107, 255, 0.22),
      0 20px 64px rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .contact-label,
  .contact-form {
    will-change: auto;
  }

  .contact-direct {
    justify-content: center;
    min-height: 17rem;
  }

  .contact-direct p {
    max-width: 27rem;
    margin: 0;
    color: color-mix(in srgb, var(--colors-fg) 86%, transparent);
    font-family: var(--fonts-serif);
    font-size: 1rem;
    line-height: 1.65;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-8);
    min-width: 0;
  }

  .form-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: rgba(245, 247, 250, 0.78);
    user-select: none;
  }

  .form-input {
    background: var(--colors-surface-contact-field);
    border: 1px solid rgba(255, 255, 255, 0.26);
    border-radius: 4px;
    color: rgba(255, 255, 255, 0.96);
    font-family: var(--fonts-mono);
    font-size: 0.875rem;
    letter-spacing: 0.02em;
    padding: var(--spacing-12) var(--spacing-16);
    width: 100%;
    box-sizing: border-box;
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .form-input::placeholder {
    color: rgba(245, 247, 250, 0.5);
  }

  .form-input:hover {
    border-color: rgba(255, 255, 255, 0.38);
    background: rgba(255, 255, 255, 0.12);
  }

  .form-input:focus {
    border-color: rgba(47, 107, 255, 0.82);
    box-shadow:
      0 0 0 2px rgba(47, 107, 255, 0.2),
      0 0 32px rgba(47, 107, 255, 0.1);
    background: rgba(47, 107, 255, 0.11);
  }

  .form-input:user-invalid {
    border-color: rgba(215, 185, 122, 0.5);
  }

  .form-textarea {
    resize: vertical;
    min-height: 9rem;
    line-height: 1.55;
  }

  .hp-trap {
    position: absolute;
    left: -9999px;
    top: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-turnstile {
    min-height: 65px;
  }

  .form-footer {
    display: flex;
    align-items: center;
    gap: var(--spacing-16);
    flex-wrap: wrap;
  }

  .form-submit {
    appearance: none;
    -webkit-appearance: none;
    background: color-mix(in srgb, var(--colors-accent) 86%, transparent);
    border: 1px solid rgba(102, 147, 255, 0.88);
    border-radius: 4px;
    color: #fff;
    cursor: pointer;
    font-family: var(--fonts-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    padding: var(--spacing-8) var(--spacing-24);
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .form-submit:hover:not(:disabled) {
    background: rgba(72, 128, 255, 0.95);
    border-color: rgba(176, 201, 255, 0.9);
    color: #fff;
  }

  .form-submit:focus-visible {
    outline: 1px dashed rgba(47, 107, 255, 0.6);
    outline-offset: 3px;
  }

  .form-submit:disabled {
    opacity: 0.52;
    cursor: not-allowed;
  }

  .form-status {
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: rgba(245, 247, 250, 0.76);
    transition: color 0.2s ease;
  }

  .form-status[data-state='success'] { color: rgba(16, 185, 129, 0.85); }
  .form-status[data-state='error']   { color: rgba(215, 185, 122, 0.85); }
  .form-status[data-state='loading'] { color: rgba(245, 245, 247, 0.4); }

  @media (max-width: 840px) {
    .contact-section {
      align-items: start;
      min-height: auto;
      padding-bottom: calc(var(--spacing-96) + env(safe-area-inset-bottom, 0px));
    }

    .contact-stage {
      grid-template-columns: 1fr;
      gap: var(--spacing-32);
    }
  }

  @media (max-width: 480px) {
    .contact-section {
      padding-inline: var(--spacing-16);
      padding-top: var(--spacing-64);
      padding-bottom: calc(var(--spacing-96) + env(safe-area-inset-bottom, 0px));
    }

    .contact-form {
      padding: var(--spacing-16);
    }

    .contact-actions :global(.heroCta) {
      width: 100%;
    }

    .form-footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-height: 520px) and (orientation: landscape) {
    .contact-section {
      min-height: auto;
    }

    .contact-label,
    .contact-form,
    .contact-stage {
      animation: none;
      clip-path: none;
      filter: none;
      opacity: 1;
      transform: none;
      will-change: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .form-input,
    .form-submit,
    .form-status {
      transition: none;
    }

    .contact-label,
    .contact-form,
    .contact-stage {
      animation: none;
      clip-path: none;
      filter: none;
      position: relative;
      top: auto;
      left: auto;
      right: auto;
      transform: none;
      will-change: auto;
      opacity: 1;
    }
  }
</style>

<script>
  import { errorMessage } from "@lib/contact-error-codes";

  const CONTACT_ENDPOINT = '/api/contact';

  function init() {
    const form     = document.getElementById('contact-form')   as HTMLFormElement   | null;
    const submitBtn = document.getElementById('cf-submit')     as HTMLButtonElement | null;
    const statusEl  = document.getElementById('cf-status')     as HTMLElement       | null;
    const widgetEl  = document.getElementById('cf-turnstile-widget') as HTMLElement | null;

    if (!form || !submitBtn || !statusEl) return;

    const siteKey = form.dataset.sitekey;
    if (!siteKey) return;

    // Dynamically load Turnstile — avoids render-blocking on pages without the form
    const script = document.createElement('script');
    script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
    script.async = true;
    script.defer = true;
    script.onload = () => {
      if (widgetEl && siteKey) {
        (window as any).turnstile?.render(widgetEl, {
          sitekey: siteKey,
          theme: 'dark',
          callback: () => { submitBtn.disabled = false; },
          'expired-callback': () => { submitBtn.disabled = true; },
        });
      }
    };
    document.head.appendChild(script);

    function setStatus(msg: string, state: 'idle' | 'loading' | 'success' | 'error') {
      statusEl!.textContent = msg;
      statusEl!.dataset.state = state;
      submitBtn!.disabled = state === 'loading';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        setStatus('', 'idle');
        return;
      }

      const token = (window as any).turnstile?.getResponse();
      if (!token) {
        setStatus('complete the captcha first', 'error');
        return;
      }

      setStatus('sending...', 'loading');

      const website = (form.elements.namedItem('website') as HTMLInputElement | null)?.value ?? '';
      const payload = {
        name:    (form.elements.namedItem('name')    as HTMLInputElement).value.trim(),
        email:   (form.elements.namedItem('email')   as HTMLInputElement).value.trim(),
        message: (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
        token,
        website,  // honeypot — humans leave empty
      };

      try {
        const res = await fetch(CONTACT_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          setStatus('sent — thanks!', 'success');
          form.reset();
          (window as any).turnstile?.reset();
          submitBtn.disabled = true;
        } else {
          const body = await res.json().catch(() => ({})) as { error?: string };
          setStatus(errorMessage(body.error ?? 'send_failed'), 'error');
          (window as any).turnstile?.reset();
        }
      } catch {
        setStatus('network error — try again', 'error');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
