---
import { SITE_LEDE } from "@config/site";
import { heroCta } from "../../styled-system/recipes";

const lede = SITE_LEDE.trim();
const ctaPrimary = heroCta({ variant: "primary" });
const ctaOutline = heroCta({ variant: "outline" });
---

{
  lede ? (
    <p class="lede">{lede}</p>
  ) : null
}

<div class="lede-cta" role="group" aria-label="Resume access">
  <a class={ctaPrimary} href="/resume">View resume</a>
  <a class={ctaOutline} href="/resume.pdf" download>Download PDF</a>
</div>

<style>
  .lede {
    max-width: min(32rem, 90vw);
    margin: 0 0 var(--spacing-24);
    padding: 0 var(--spacing-16);
    font-size: 1rem;
    line-height: 1.5;
    font-weight: 400;
    letter-spacing: 0.01em;
    text-align: center;
    color: var(--colors-muted);
  }

  .lede-cta {
    display: flex;
    justify-content: center;
    gap: var(--spacing-12);
    margin: 0 0 var(--spacing-24);
    flex-wrap: wrap;
  }
</style>
