---
import { portfolio } from '../data/portfolio';
import ThemeToggle from './theme-toggle.astro';

const { brand, nav, navLabel } = portfolio;
---

<header class="site-header">
  <a class="brand-mark" href="#home" aria-label={brand.homeLabel}>
    <span>{brand.prefix}</span><strong>{brand.suffix}</strong>
  </a>

  <nav class="site-nav" aria-label={navLabel}>
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>

  <ThemeToggle />
</header>

<style>
  .site-header {
    position: sticky;
    top: 0.75rem;
    z-index: 40;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    width: min(1180px, calc(100% - 2rem));
    margin: 0.75rem auto 0;
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    padding: 0.45rem;
    background: color-mix(in srgb, var(--color-background) 82%, transparent);
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(18px);
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    border-radius: 999px;
    padding: 0 0.85rem;
    color: var(--color-maintext);
    font-family: var(--font-heading);
    font-size: 0.94rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-decoration: none;
  }

  .brand-mark strong {
    color: var(--color-accent-text);
    font-weight: inherit;
  }

  .site-nav {
    display: flex;
    justify-content: center;
    gap: 0.15rem;
    min-width: 0;
  }

  .site-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    border-radius: 999px;
    padding: 0 0.8rem;
    color: var(--color-subtext);
    font-size: 0.84rem;
    font-weight: 800;
    text-decoration: none;
    transition:
      background-color 160ms ease,
      color 160ms ease;
  }

  .site-nav a:hover,
  .site-nav a.is-active {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-maintext);
  }

  :global(.theme-toggle) {
    justify-self: end;
  }

  @media (max-width: 760px) {
    .site-header {
      top: 0.5rem;
      grid-template-columns: 1fr auto;
      width: auto;
      margin: 0.5rem;
      padding: 0.35rem;
      border-radius: 18px;
    }

    .brand-mark {
      display: none;
    }

    .site-nav {
      justify-content: space-between;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .site-nav::-webkit-scrollbar {
      display: none;
    }

    .site-nav a {
      min-height: 2.65rem;
      padding: 0 0.54rem;
      font-size: 0.72rem;
      white-space: nowrap;
    }
  }

  @media (max-width: 360px) {
    .site-header {
      gap: 0.35rem;
    }

    .site-nav a {
      padding: 0 0.38rem;
      font-size: 0.66rem;
    }
  }
</style>
