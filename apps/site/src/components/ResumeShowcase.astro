---
import { HOME_RESUME_SECTION_DECK } from "@config/site";
import { resumeSnapshotForPage } from "@lib/resume-page-snapshot";
/** Homepage resume band — section rhythm inspired by career timeline / project grid patterns (e.g. nbakh16/career-portfolio-template); copy and data from `resume.toml` via snapshot. */
import { Icon } from "astro-icon/components";

const resume = resumeSnapshotForPage().data;
const primaryExperience = resume.experience.slice(0, 4);
const skillGroups = Object.entries(resume.skills);

/**
 * Map a free-form skill label (from `resume.toml`) to a local icon name in
 * `src/icons/<name>.svg`. The SVGs were extracted from `@iconify-json/simple-icons`
 * via `scripts/sync-tech-icons.ts`. Returns null when no clean brand match
 * exists; the markup falls back to a small bullet so the row keeps its rhythm.
 */
function skillIcon(skill: string): string | null {
  const s = skill.toLowerCase().trim();
  if (/^python/.test(s)) return "python";
  if (/^c\+\+/.test(s)) return "cplusplus";
  if (/^c$/.test(s)) return "c";
  if (/c#|\.net/.test(s)) return "dotnet";
  if (/^bash$|shell/.test(s)) return "gnubash";
  if (/powershell/.test(s)) return "powershell";
  if (/docker/.test(s)) return "docker";
  if (/github actions|ci\/cd/.test(s)) return "githubactions";
  if (/gitlab/.test(s)) return "gitlab";
  if (/^linux/.test(s)) return "linux";
  if (/elasticsearch/.test(s)) return "elasticsearch";
  if (/kafka/.test(s)) return "apachekafka";
  if (/nifi/.test(s)) return "apachenifi";
  if (/spark/.test(s)) return "apachespark";
  if (/^sql$/.test(s)) return "mysql";
  return null;
}

/** Skill pillars from `resume.toml` plus distinct role tags — no orphaned hard-coded fit copy. */
const skillGroupNames = Object.keys(resume.skills);
const seenChip = new Set<string>(skillGroupNames.map((s) => s.toLowerCase()));
const focusChips: string[] = [...skillGroupNames];
for (const job of primaryExperience) {
  if (focusChips.length >= 8) break;
  for (const tag of job.skills) {
    if (focusChips.length >= 8) break;
    const key = tag.toLowerCase();
    if (seenChip.has(key)) continue;
    seenChip.add(key);
    focusChips.push(tag.charAt(0).toUpperCase() + tag.slice(1));
  }
}

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

function truncateTeaser(text: string, max: number): string {
  const t = text.trim();
  if (t.length <= max) return t;
  const cut = t.slice(0, max - 1);
  const lastSpace = cut.lastIndexOf(" ");
  return `${(lastSpace > Math.floor(max * 0.55) ? cut.slice(0, lastSpace) : cut).trim()}…`;
}

type Job = (typeof resume.experience)[number];

function jobPresentation(job: Job): { teaser: string; bullets: string[] } {
  const hs = job.highlights ?? [];
  const summary = job.summary.trim();
  if (summary) {
    return { teaser: truncateTeaser(summary, 240), bullets: hs };
  }
  if (!hs.length) return { teaser: "", bullets: [] };
  const lead = hs[0] ?? "";
  return {
    teaser: truncateTeaser(lead, 240),
    bullets: hs.slice(1),
  };
}

/** Social / profile links from resume payload (drops self-site pill). */
const linkPills = resume.links.filter((l) => l.label.trim() && l.url.trim() && !/yanai\.sh/i.test(l.label));

const showcasedProjects = resume.projects.slice(0, 2);
---

<section
  class="resume-showcase"
  id="resume"
  data-bg-variant="resume"
  aria-labelledby="resume-showcase-title"
  tabindex="-1"
>
  <div class="resume-inner">
    <header class="resume-intro">
      <h2 class="section-heading section-heading--display" id="resume-showcase-title">
        <span aria-hidden="true" class="slash">/</span> Resume
      </h2>
      <p class="section-deck">{HOME_RESUME_SECTION_DECK}</p>
      <p class="display-name">{resume.header.name}</p>
      <p class="headline">{resume.header.headline}</p>
      <p class="summary">{resume.summary}</p>

      <ul class="fit-snapshot" aria-label="Technical focus derived from resume">
        {focusChips.map((item) => (
          <li class="tag-chip">{item}</li>
        ))}
      </ul>

      <div class="resume-intro-footer">
        <dl class="resume-meta" aria-label="Resume contact">
          <div>
            <dt class="sr-only">Location</dt>
            <dd>{resume.header.location}</dd>
          </div>
          <div>
            <dt class="sr-only">Email</dt>
            <dd>
              <a href={`mailto:${resume.header.email}`}>{resume.header.email}</a>
            </dd>
          </div>
        </dl>

        {
          linkPills.length ? (
            <nav class="resume-quick-links" aria-label="Profiles and links">
              <ul>
                {linkPills.map((link) => (
                  <li>
                    <a href={link.url} rel="noopener noreferrer" target="_blank">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          ) : null
        }
      </div>
    </header>

    <section class="resume-timeline-shell" aria-labelledby="resume-career-heading">
      <div class="resume-timeline-heading">
        <h3 id="resume-career-heading" class="section-heading section-heading--sub">
          <span aria-hidden="true" class="slash">/</span> Roles & impact
        </h3>
        <p class="section-deck">
          Representative engagements — <a href="/resume">the canonical resume</a> stays on its own page.
        </p>
      </div>

      <ol class="resume-timeline" aria-label="Career timeline">
        {
          primaryExperience.map((job, index) => {
            const { teaser, bullets } = jobPresentation(job);
            return (
              <li class={`career-card ${index % 2 === 0 ? "career-card--left" : "career-card--right"}`}>
                <span class={`timeline-dot ${index === 0 ? "timeline-dot--active" : ""}`} aria-hidden="true" />
                <article class="card career-card-body">
                  <p class="period">{job.period}</p>
                  <h4 class="role-title">{job.role}</h4>
                  <p class="company-line">
                    {job.company}
                    {job.location ? <span class="company-location"> / {job.location}</span> : null}
                  </p>
                  {job.subtitle ? <p class="flavor-line">{job.subtitle}</p> : null}
                  {teaser ? <p class="job-teaser">{teaser}</p> : null}
                  {
                    bullets.length ? (
                      <ul class="career-highlights">
                        {bullets.slice(0, 5).map((highlight) => (
                          <li>{highlight}</li>
                        ))}
                      </ul>
                    ) : null
                  }
                  {
                    job.skills.length ? (
                      <div class="tag-list" aria-label={`${job.company} skills`}>
                        {job.skills.map((skill) => (
                          <span class="tag-chip">{skill}</span>
                        ))}
                      </div>
                    ) : null
                  }
                </article>
              </li>
            );
          })
        }
      </ol>
    </section>

    <div class="resume-lower">
      {
        showcasedProjects.length ? (
          <section class="resume-panel resume-panel--projects card" aria-labelledby="resume-project-title">
            <div class="panel-heading">
              <h3 id="resume-project-title" class="section-heading section-heading--sub">
                <span aria-hidden="true" class="slash">/</span> Projects
              </h3>
              <p class="section-deck">Shipped systems and tooling called out on the canonical CV.</p>
            </div>
            <div class="project-grid">
              {
                showcasedProjects.map((project) => (
                  <article class="card project-card">
                    <h4>{project.name}</h4>
                    {project.description ? <p class="project-role">{project.description}</p> : null}
                    <ul class="project-highlights">
                      {project.highlights.map((highlight) => (
                        <li>{highlight}</li>
                      ))}
                    </ul>
                  </article>
                ))
              }
            </div>
          </section>
        ) : null
      }

      <section class="resume-panel resume-panel--skills card" aria-labelledby="resume-skills-title">
        <div class="panel-heading">
          <h3 id="resume-skills-title" class="section-heading section-heading--sub">
            <span aria-hidden="true" class="slash">/</span> Technical profile
          </h3>
          <p class="section-deck">Grouped competencies from <code>resume.toml</code>.</p>
        </div>
        <div class="skill-grid">
          {
            skillGroups.map(([group, items]) => (
              <section class="skill-group" aria-labelledby={`home-skill-${slugify(group)}`}>
                <h4 id={`home-skill-${slugify(group)}`}>{group}</h4>
                <ul class="skill-list" aria-label={`${group} skills`}>
                  {items.slice(0, 8).map((item) => {
                    const iconName = skillIcon(item);
                    return (
                      <li class="skill-item">
                        <span class="skill-glyph" aria-hidden="true">
                          {iconName ? (
                            <Icon name={iconName} class="skill-icon" />
                          ) : (
                            <span class="skill-bullet" />
                          )}
                        </span>
                        <span class="skill-name">{item}</span>
                      </li>
                    );
                  })}
                </ul>
              </section>
            ))
          }
        </div>
      </section>

      <section class="resume-panel resume-panel--compact card" aria-labelledby="resume-education-title">
        <div class="panel-heading">
          <h3 id="resume-education-title" class="section-heading section-heading--sub">
            <span aria-hidden="true" class="slash">/</span> Education, training & languages
          </h3>
          <p class="section-deck">Formal study and certifications alongside working languages.</p>
        </div>

        {
          resume.languages.length ? (
            <ul class="lang-chips" aria-label="Languages">
              {resume.languages.map((lang) => (
                <li>
                  <span class="lang-name">{lang.name}</span>
                  <span class="lang-level">{lang.proficiency}</span>
                </li>
              ))}
            </ul>
          ) : null
        }

        <div class="education-stack">
          {
            [...resume.training, ...resume.education].slice(0, 4).map((entry) => (
              <article class="education-line">
                <p class="period">{entry.period}</p>
                <h4>{entry.degree}</h4>
                <p class="meta">
                  {entry.institution}
                  {entry.location ? ` / ${entry.location}` : ""}
                </p>
              </article>
            ))
          }
        </div>
      </section>
    </div>
  </div>
</section>

<style>
  .resume-showcase {
    position: relative;
    z-index: 10;
    width: 100%;
    min-width: 0;
    overflow: clip;
    padding:
      clamp(var(--spacing-64), 12vh, 9rem)
      max(var(--spacing-16), min(var(--spacing-48), 5vi))
      clamp(var(--spacing-64), 12vh, var(--spacing-96));
    box-sizing: border-box;
  }

  .resume-showcase:focus {
    outline: none;
  }

  .resume-showcase {
    --section-grid-size: 30px;
    --section-grid-alpha: 0.016;
  }

  .resume-inner {
    width: min(76rem, 100%);
    margin: 0 auto;
    display: grid;
    gap: clamp(var(--spacing-48), 7vw, var(--spacing-96));
  }

  .resume-intro {
    display: grid;
    gap: var(--spacing-12);
    max-width: 54rem;
    min-width: 0;
  }

  .period,
  .meta {
    margin: 0;
    color: color-mix(in srgb, var(--colors-muted) 86%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .display-name {
    margin: var(--spacing-16) 0 0;
    color: var(--colors-fg);
    font-family: var(--fonts-mono);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }

  .headline {
    margin: 0;
    color: color-mix(in srgb, var(--colors-accent) 82%, var(--colors-fg));
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    font-weight: 700;
    line-height: 1.35;
  }

  .summary {
    max-width: 50rem;
    margin: var(--spacing-8) 0 0;
    color: color-mix(in srgb, var(--colors-fg) 78%, transparent);
    font-family: var(--fonts-serif);
    font-size: clamp(1rem, 1.3vw, 1.0625rem);
    line-height: 1.7;
  }

  .fit-snapshot {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
    margin: var(--spacing-8) 0 0;
    padding: 0;
    list-style: none;
  }

  .resume-intro-footer {
    display: grid;
    gap: var(--spacing-16);
    margin-top: var(--spacing-8);
    padding-top: var(--spacing-16);
    border-top: 1px solid rgba(245, 245, 247, 0.1);
    max-width: 48rem;
  }

  .resume-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8) var(--spacing-16);
    margin: 0;
    color: color-mix(in srgb, var(--colors-fg) 68%, transparent);
    font-size: 0.8125rem;
    line-height: 1.4;
  }

  .resume-meta div,
  .resume-meta dd {
    margin: 0;
  }

  .resume-meta a {
    color: inherit;
    text-decoration-color: rgba(47, 107, 255, 0.5);
    text-underline-offset: 0.22em;
  }

  .resume-quick-links ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .resume-quick-links a {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-4);
    border: 1px solid rgba(245, 245, 247, 0.12);
    padding: 0.35rem 0.65rem;
    color: color-mix(in srgb, var(--colors-fg) 74%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }

  .resume-quick-links a:hover,
  .resume-quick-links a:focus-visible {
    border-color: color-mix(in srgb, var(--colors-accent) 45%, transparent);
    color: var(--colors-fg);
  }

  /* --- Timeline shell --- */
  .resume-timeline-shell {
    display: grid;
    gap: var(--spacing-32);
    min-width: 0;
  }

  .resume-timeline-heading {
    display: grid;
    gap: var(--spacing-8);
    max-width: 40rem;
  }

  /* --- Timeline --- */
  .resume-timeline {
    position: relative;
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .resume-timeline::before {
    content: "";
    position: absolute;
    top: var(--spacing-8);
    bottom: var(--spacing-8);
    left: 50%;
    width: 1px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--colors-accent) 72%, transparent),
      rgba(245, 245, 247, 0.08) 54%,
      transparent
    );
    transform: translateX(-50%);
  }

  .career-card {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-width: 0;
  }

  .career-card + .career-card {
    margin-top: clamp(-9.5rem, -10.5vw, -6rem);
  }

  .career-card article {
    display: contents;
  }

  .career-card--left .career-card-body {
    grid-column: 1;
    text-align: right;
  }

  .career-card--right .career-card-body {
    grid-column: 2;
  }

  .timeline-dot {
    position: absolute;
    top: var(--spacing-16);
    left: 50%;
    z-index: 2;
    width: 0.875rem;
    height: 0.875rem;
    border: 3px solid var(--colors-bg);
    border-radius: 999px;
    background: color-mix(in srgb, var(--colors-accent) 60%, transparent);
    transform: translateX(-50%);
  }

  .timeline-dot--active {
    background: var(--colors-accent);
    box-shadow: 0 0 22px color-mix(in srgb, var(--colors-accent) 46%, transparent);
    animation: dot-pulse 2.8s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--colors-accent) 38%, transparent);
    }
    50% {
      box-shadow: 0 0 0 9px color-mix(in srgb, var(--colors-accent) 0%, transparent);
    }
  }

  .career-card-body {
    display: grid;
    gap: var(--spacing-12);
    padding: clamp(var(--spacing-16), 3vw, var(--spacing-24));
    min-width: 0;
  }

  .career-card--left .career-card-body {
    margin-right: clamp(var(--spacing-32), 6vw, var(--spacing-64));
  }

  .career-card--right .career-card-body {
    margin-left: clamp(var(--spacing-32), 6vw, var(--spacing-64));
  }

  .role-title,
  .resume-panel h4 {
    margin: 0;
    color: var(--colors-fg);
    letter-spacing: 0;
  }

  .role-title {
    font-size: clamp(1.125rem, 1.8vw, 1.4rem);
    line-height: 1.24;
    font-weight: 800;
  }

  .company-line,
  .flavor-line {
    margin: 0;
    color: color-mix(in srgb, var(--colors-muted) 86%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .flavor-line {
    color: color-mix(in srgb, var(--colors-accent) 76%, var(--colors-fg));
  }

  .job-teaser {
    margin: 0;
    color: color-mix(in srgb, var(--colors-fg) 76%, transparent);
    font-family: var(--fonts-serif);
    font-size: 0.9rem;
    line-height: 1.62;
    text-align: inherit;
  }

  .career-card--left .job-teaser,
  .career-card--left .career-highlights {
    margin-left: auto;
    max-width: 38rem;
  }

  .career-card ul,
  .resume-panel ul {
    display: grid;
    gap: var(--spacing-8);
    margin: 0;
    padding-left: 1.1rem;
    color: color-mix(in srgb, var(--colors-fg) 76%, transparent);
    font-family: var(--fonts-serif);
    font-size: 0.875rem;
    line-height: 1.62;
    text-align: left;
  }

  .career-card--left ul.career-highlights {
    text-align: right;
    direction: rtl;
    padding-left: 0;
    padding-right: 1.1rem;
  }

  .career-card--left ul.career-highlights > li {
    direction: ltr;
  }

  .career-card li::marker,
  .resume-panel li::marker {
    color: var(--colors-accent);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }

  .career-card--left .tag-list {
    justify-content: flex-end;
  }

  /* --- Lower grid --- */
  .resume-lower {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.35fr);
    gap: var(--spacing-24);
    align-items: start;
  }

  .resume-panel--projects {
    grid-column: 1;
  }

  .resume-panel--skills {
    grid-column: 2;
  }

  .resume-lower:not(:has(.resume-panel--projects)) .resume-panel--skills {
    grid-column: 1 / -1;
  }

  .resume-panel {
    display: grid;
    align-content: start;
    gap: var(--spacing-16);
    padding: clamp(var(--spacing-16), 3vw, var(--spacing-24));
  }

  .resume-panel--compact {
    grid-column: 1 / -1;
  }

  .panel-heading {
    display: grid;
    gap: var(--spacing-8);
    min-width: 0;
  }

  .resume-panel h4 {
    font-size: 0.95rem;
    line-height: 1.35;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-16);
  }

  .project-card {
    display: grid;
    gap: var(--spacing-8);
    min-width: 0;
    padding: var(--spacing-16);
  }

  .project-card h4 {
    font-size: 1rem;
  }

  .project-role {
    margin: calc(var(--spacing-4) * -1) 0 0;
    color: color-mix(in srgb, var(--colors-muted) 88%, transparent);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-highlights {
    margin: 0 !important;
    padding-left: 1.05rem !important;
    font-size: 0.8125rem !important;
    line-height: 1.55 !important;
  }

  .skill-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-16);
  }

  .skill-group {
    display: grid;
    gap: var(--spacing-8);
    min-width: 0;
    padding-top: var(--spacing-12);
    border-top: 1px solid rgba(245, 245, 247, 0.08);
  }

  .skill-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(11rem, 100%), 1fr));
    gap: var(--spacing-8);
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  .skill-item {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 2.25rem;
    padding: 0.32rem 0.55rem 0.32rem 0.42rem;
    border: 1px solid color-mix(in srgb, var(--colors-fg) 12%, transparent);
    border-radius: 8px;
    background: color-mix(in srgb, var(--colors-accent) 4%, transparent);
    color: color-mix(in srgb, var(--colors-fg) 78%, transparent);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.01em;
    transition:
      border-color 0.3s ease,
      background 0.3s ease,
      color 0.3s ease;
  }

  .skill-glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 1.55rem;
    height: 1.55rem;
    border-radius: 6px;
    background: color-mix(in srgb, var(--colors-accent) 12%, transparent);
    color: color-mix(in srgb, var(--colors-fg) 92%, transparent);
    transition:
      background 0.3s ease,
      color 0.3s ease;
  }

  .skill-glyph :global(.skill-icon) {
    width: 1.05rem;
    height: 1.05rem;
  }

  .skill-bullet {
    display: inline-block;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--colors-accent) 65%, transparent);
  }

  .skill-name {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

