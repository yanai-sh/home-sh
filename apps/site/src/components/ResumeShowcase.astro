---
/** Homepage resume band — section rhythm inspired by career timeline / project grid patterns (e.g. nbakh16/career-portfolio-template); copy and data from `resume.toml` via snapshot. */
import { HOME_RESUME_SECTION_DECK } from "@config/site";
import { resumeSnapshotForPage } from "@lib/resume-page-snapshot";

const resume = resumeSnapshotForPage().data;
const primaryExperience = resume.experience.slice(0, 4);
const skillGroups = Object.entries(resume.skills);

/** Skill pillars from `resume.toml` plus distinct role tags — no orphaned hard-coded fit copy. */
const skillGroupNames = Object.keys(resume.skills);
const seenChip = new Set<string>(skillGroupNames.map((s) => s.toLowerCase()));
const focusChips: string[] = [...skillGroupNames];
for (const job of primaryExperience) {
  if (focusChips.length >= 8) break;
  for (const tag of job.skills) {
    if (focusChips.length >= 8) break;
    const key = tag.toLowerCase();
    if (seenChip.has(key)) continue;
    seenChip.add(key);
    focusChips.push(tag.charAt(0).toUpperCase() + tag.slice(1));
  }
}

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

function truncateTeaser(text: string, max: number): string {
  const t = text.trim();
  if (t.length <= max) return t;
  const cut = t.slice(0, max - 1);
  const lastSpace = cut.lastIndexOf(" ");
  return `${(lastSpace > Math.floor(max * 0.55) ? cut.slice(0, lastSpace) : cut).trim()}…`;
}

type Job = (typeof resume.experience)[number];

function jobPresentation(job: Job): { teaser: string; bullets: string[] } {
  const hs = job.highlights ?? [];
  const summary = job.summary.trim();
  if (summary) {
    return { teaser: truncateTeaser(summary, 240), bullets: hs };
  }
  if (!hs.length) return { teaser: "", bullets: [] };
  const lead = hs[0] ?? "";
  return {
    teaser: truncateTeaser(lead, 240),
    bullets: hs.slice(1),
  };
}

/** Social / profile links from resume payload (drops self-site pill). */
const linkPills = resume.links.filter((l) => l.label.trim() && l.url.trim() && !/yanai\.sh/i.test(l.label));

const showcasedProjects = resume.projects.slice(0, 2);
---

<section
  class="resume-showcase"
  id="resume"
  data-bg-variant="resume"
  aria-labelledby="resume-showcase-title"
  tabindex="-1"
>
  <span class="resume-roll-index" aria-hidden="true">02</span>

  <div class="resume-inner">
    <header class="resume-intro">
      <p class="chapter-kicker">02 / resume</p>
      <p class="resume-section-deck">{HOME_RESUME_SECTION_DECK}</p>
      <h2 id="resume-showcase-title">{resume.header.name}</h2>
      <p class="headline">{resume.header.headline}</p>
      <p class="summary">{resume.summary}</p>

      <ul class="fit-snapshot" aria-label="Technical focus derived from résumé">
        {focusChips.map((item) => (
          <li>{item}</li>
        ))}
      </ul>

      <div class="resume-intro-footer">
        <dl class="resume-meta" aria-label="Résumé contact">
          <div>
            <dt class="sr-only">Location</dt>
            <dd>{resume.header.location}</dd>
          </div>
          <div>
            <dt class="sr-only">Email</dt>
            <dd>
              <a href={`mailto:${resume.header.email}`}>{resume.header.email}</a>
            </dd>
          </div>
        </dl>

        {
          linkPills.length ? (
            <nav class="resume-quick-links" aria-label="Profiles and links">
              <ul>
                {linkPills.map((link) => (
                  <li>
                    <a href={link.url} rel="noopener noreferrer" target="_blank">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          ) : null
        }
      </div>
    </header>

    <section class="resume-timeline-shell" aria-labelledby="resume-career-heading">
      <div class="resume-timeline-heading">
        <p class="timeline-eyebrow">Experience</p>
        <h3 id="resume-career-heading">Roles & impact</h3>
        <p class="timeline-deck muted">Representative engagements — full detail on <a href="/resume">the résumé page</a>.</p>
      </div>

      <ol class="resume-timeline" aria-label="Career timeline">
        {
          primaryExperience.map((job, index) => {
            const { teaser, bullets } = jobPresentation(job);
            return (
              <li class={`career-card ${index % 2 === 0 ? "career-card--left" : "career-card--right"}`}>
                <article>
                  <span class="timeline-dot" aria-hidden="true" />
                  <div class="career-card-body">
                    <p class="period">{job.period}</p>
                    <h3>{job.role}</h3>
                    <p class="company-line">
                      {job.company}
                      {job.location ? <span class="company-location"> / {job.location}</span> : null}
                    </p>
                    {job.subtitle ? <p class="flavor-line">{job.subtitle}</p> : null}
                    {teaser ? <p class="job-teaser">{teaser}</p> : null}
                    {
                      bullets.length ? (
                        <ul class="career-highlights">
                          {bullets.slice(0, 5).map((highlight) => (
                            <li>{highlight}</li>
                          ))}
                        </ul>
                      ) : null
                    }
                    {
                      job.skills.length ? (
                        <div class="tag-list" aria-label={`${job.company} skills`}>
                          {job.skills.map((skill) => (
                            <span>{skill}</span>
                          ))}
                        </div>
                      ) : null
                    }
                  </div>
                </article>
              </li>
            );
          })
        }
      </ol>
    </section>

    <div class="resume-lower">
      {
        showcasedProjects.length ? (
          <section class="resume-panel resume-panel--projects" aria-labelledby="resume-project-title">
            <p class="panel-index">03</p>
            <div class="panel-heading">
              <h3 id="resume-project-title">Projects</h3>
              <p class="panel-deck muted">Shipped systems and tooling called out on the canonical CV.</p>
            </div>
            <div class="project-grid">
              {
                showcasedProjects.map((project) => (
                  <article class="project-card">
                    <h4>{project.name}</h4>
                    {project.description ? <p class="project-role">{project.description}</p> : null}
                    <ul class="project-highlights">
                      {project.highlights.map((highlight) => (
                        <li>{highlight}</li>
                      ))}
                    </ul>
                  </article>
                ))
              }
            </div>
          </section>
        ) : null
      }

      <section class="resume-panel resume-panel--skills" aria-labelledby="resume-skills-title">
        <p class="panel-index">{showcasedProjects.length ? "04" : "03"}</p>
        <div class="panel-heading">
          <h3 id="resume-skills-title">Technical profile</h3>
          <p class="panel-deck muted">Grouped competencies from <code class="resume-code">resume.toml</code>.</p>
        </div>
        <div class="skill-grid">
          {
            skillGroups.map(([group, items]) => (
              <section class="skill-group" aria-labelledby={`home-skill-${slugify(group)}`}>
                <h4 id={`home-skill-${slugify(group)}`}>{group}</h4>
                <ul class="skill-list" aria-label={`${group} skills`}>
                  {items.slice(0, 6).map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>
      </section>

      <section class="resume-panel resume-panel--compact" aria-labelledby="resume-education-title">
        <p class="panel-index">{showcasedProjects.length ? "05" : "04"}</p>
        <div class="panel-heading">
          <h3 id="resume-education-title">Education, training & languages</h3>
          <p class="panel-deck muted">Formal study and certifications alongside working languages.</p>
        </div>

        {
          resume.languages.length ? (
            <ul class="lang-chips" aria-label="Languages">
              {resume.languages.map((lang) => (
                <li>
                  <span class="lang-name">{lang.name}</span>
                  <span class="lang-level">{lang.proficiency}</span>
                </li>
              ))}
            </ul>
          ) : null
        }

        <div class="education-stack">
          {
            [...resume.training, ...resume.education].slice(0, 4).map((entry) => (
              <article class="education-line">
                <p class="period">{entry.period}</p>
                <h4>{entry.degree}</h4>
                <p class="meta">
                  {entry.institution}
                  {entry.location ? ` / ${entry.location}` : ""}
                </p>
              </article>
            ))
          }
        </div>
      </section>
    </div>
  </div>
</section>

<style>
  .resume-showcase {
    position: relative;
    z-index: 10;
    width: 100%;
    min-width: 0;
    overflow: clip;
    padding:
      clamp(var(--spacing-64), 12vh, 9rem)
      max(var(--spacing-16), min(var(--spacing-48), 5vi))
      clamp(var(--spacing-64), 12vh, var(--spacing-96));
    box-sizing: border-box;
  }

  .resume-showcase:focus {
    outline: none;
  }

  .resume-showcase {
    --section-grid-size: 30px;
    --section-grid-alpha: 0.016;
  }

  .resume-inner {
    width: min(76rem, 100%);
    margin: 0 auto;
    display: grid;
    gap: clamp(var(--spacing-48), 7vw, var(--spacing-96));
  }

  .resume-intro {
    display: grid;
    gap: var(--spacing-16);
    max-width: 54rem;
    min-width: 0;
  }

  .chapter-kicker,
  .period,
  .meta,
  .panel-index,
  .timeline-eyebrow {
    margin: 0;
    color: color-mix(in srgb, var(--colors-muted) 86%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .resume-section-deck {
    margin: calc(var(--spacing-4) * -1) 0 0;
    max-width: 42rem;
    color: color-mix(in srgb, var(--colors-fg) 62%, transparent);
    font-size: clamp(0.9375rem, 1.2vw, 1.0625rem);
    font-weight: 600;
    line-height: 1.45;
  }

  .resume-intro h2 {
    margin: 0;
    color: var(--colors-fg);
    font-size: clamp(3rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: 0;
  }

  .headline {
    margin: 0;
    color: color-mix(in srgb, var(--colors-accent) 82%, var(--colors-fg));
    font-size: clamp(1.1rem, 2vw, 1.55rem);
    font-weight: 700;
    line-height: 1.25;
  }

  .summary {
    max-width: 50rem;
    margin: var(--spacing-8) 0 0;
    color: color-mix(in srgb, var(--colors-fg) 78%, transparent);
    font-family: var(--fonts-serif);
    font-size: clamp(1rem, 1.35vw, 1.125rem);
    line-height: 1.75;
  }

  .fit-snapshot {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
    margin: var(--spacing-12) 0 0;
    padding: 0;
    list-style: none;
  }

  .fit-snapshot li {
    border: 1px solid color-mix(in srgb, var(--colors-accent) 28%, transparent);
    padding: 0.38rem 0.65rem;
    color: color-mix(in srgb, var(--colors-accent) 78%, var(--colors-fg));
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .resume-intro-footer {
    display: grid;
    gap: var(--spacing-16);
    margin-top: var(--spacing-8);
    padding-top: var(--spacing-16);
    border-top: 1px solid rgba(245, 245, 247, 0.1);
    max-width: 48rem;
  }

  .resume-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8) var(--spacing-16);
    margin: 0;
    color: color-mix(in srgb, var(--colors-fg) 68%, transparent);
    font-size: 0.8125rem;
    line-height: 1.4;
  }

  .resume-meta div,
  .resume-meta dd {
    margin: 0;
  }

  .resume-meta a {
    color: inherit;
    text-decoration-color: rgba(47, 107, 255, 0.5);
    text-underline-offset: 0.22em;
  }

  .resume-quick-links ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .resume-quick-links a {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-4);
    border: 1px solid rgba(245, 245, 247, 0.12);
    padding: 0.35rem 0.65rem;
    color: color-mix(in srgb, var(--colors-fg) 74%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }

  .resume-quick-links a:hover,
  .resume-quick-links a:focus-visible {
    border-color: color-mix(in srgb, var(--colors-accent) 45%, transparent);
    color: var(--colors-fg);
  }

  /* --- Timeline shell (portfolio-style section header) --- */
  .resume-timeline-shell {
    display: grid;
    gap: var(--spacing-32);
    min-width: 0;
  }

  .resume-timeline-heading {
    display: grid;
    gap: var(--spacing-8);
    max-width: 40rem;
  }

  .resume-timeline-heading h3 {
    margin: 0;
    font-size: clamp(1.5rem, 4vw, 2.125rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: 0;
    color: var(--colors-fg);
  }

  .timeline-deck,
  .panel-deck {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .timeline-deck.muted,
  .panel-deck.muted {
    color: color-mix(in srgb, var(--colors-muted) 88%, var(--colors-fg));
  }

  .timeline-deck a {
    color: color-mix(in srgb, var(--colors-accent) 78%, var(--colors-fg));
    text-underline-offset: 0.2em;
  }

  /* --- Timeline --- */
  .resume-timeline {
    position: relative;
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .resume-timeline::before {
    content: "";
    position: absolute;
    top: var(--spacing-8);
    bottom: var(--spacing-8);
    left: 50%;
    width: 1px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--colors-accent) 72%, transparent),
      rgba(245, 245, 247, 0.08) 54%,
      transparent
    );
    transform: translateX(-50%);
  }

  .career-card {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-width: 0;
  }

  .career-card + .career-card {
    margin-top: clamp(-9.5rem, -10.5vw, -6rem);
  }

  .career-card article {
    display: contents;
  }

  .career-card--left .career-card-body {
    grid-column: 1;
    text-align: right;
  }

  .career-card--right .career-card-body {
    grid-column: 2;
  }

  .timeline-dot {
    position: absolute;
    top: var(--spacing-16);
    left: 50%;
    z-index: 1;
    width: 0.875rem;
    height: 0.875rem;
    border: 3px solid var(--colors-bg);
    background: var(--colors-accent);
    box-shadow: 0 0 22px color-mix(in srgb, var(--colors-accent) 46%, transparent);
    transform: translateX(-50%);
  }

  .career-card-body,
  .resume-panel {
    min-width: 0;
    border: 1px solid rgba(245, 245, 247, 0.1);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(245, 247, 250, 0.072), rgba(245, 247, 250, 0.032)),
      color-mix(in srgb, var(--colors-surface) 78%, transparent);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.26);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .career-card-body {
    display: grid;
    gap: var(--spacing-12);
    padding: clamp(var(--spacing-16), 3vw, var(--spacing-24));
  }

  .career-card--left .career-card-body {
    margin-right: clamp(var(--spacing-32), 6vw, var(--spacing-64));
  }

  .career-card--right .career-card-body {
    margin-left: clamp(var(--spacing-32), 6vw, var(--spacing-64));
  }

  .career-card h3,
  .resume-panel h3,
  .resume-panel h4 {
    margin: 0;
    color: var(--colors-fg);
    letter-spacing: 0;
  }

  .career-card h3 {
    font-size: clamp(1.125rem, 1.8vw, 1.45rem);
    line-height: 1.24;
  }

  .company-line,
  .flavor-line {
    margin: 0;
    color: color-mix(in srgb, var(--colors-muted) 86%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .flavor-line {
    color: color-mix(in srgb, var(--colors-accent) 76%, var(--colors-fg));
  }

  .job-teaser {
    margin: 0;
    color: color-mix(in srgb, var(--colors-fg) 76%, transparent);
    font-family: var(--fonts-serif);
    font-size: 0.9rem;
    line-height: 1.62;
    text-align: inherit;
  }

  .career-card--left .job-teaser,
  .career-card--left .career-highlights {
    margin-left: auto;
    max-width: 38rem;
  }

  .career-card ul,
  .resume-panel ul {
    display: grid;
    gap: var(--spacing-8);
    margin: 0;
    padding-left: 1.1rem;
    color: color-mix(in srgb, var(--colors-fg) 76%, transparent);
    font-family: var(--fonts-serif);
    font-size: 0.875rem;
    line-height: 1.62;
    text-align: left;
  }

  .career-card--left ul.career-highlights {
    text-align: right;
    direction: rtl;
    padding-left: 0;
    padding-right: 1.1rem;
  }

  .career-card--left ul.career-highlights > li {
    direction: ltr;
  }

  .career-card li::marker,
  .resume-panel li::marker {
    color: var(--colors-accent);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }

  .career-card--left .tag-list {
    justify-content: flex-end;
  }

  .tag-list span {
    border: 1px solid color-mix(in srgb, var(--colors-accent) 26%, transparent);
    padding: 0.25rem 0.5rem;
    color: color-mix(in srgb, var(--colors-accent) 82%, var(--colors-fg));
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  /* --- Lower grid --- */
  .resume-lower {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.35fr);
    gap: var(--spacing-24);
    align-items: start;
  }

  .resume-panel--projects {
    grid-column: 1;
  }

  .resume-panel--skills {
    grid-column: 2;
  }

  .resume-lower:not(:has(.resume-panel--projects)) .resume-panel--skills {
    grid-column: 1 / -1;
  }

  .resume-panel {
    display: grid;
    align-content: start;
    gap: var(--spacing-16);
    padding: clamp(var(--spacing-16), 3vw, var(--spacing-24));
  }

  .resume-panel--compact {
    grid-column: 1 / -1;
  }

  .resume-panel h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .panel-heading {
    display: grid;
    gap: var(--spacing-4);
    min-width: 0;
  }

  .resume-panel h4 {
    font-size: 0.95rem;
    line-height: 1.35;
  }

  .resume-code {
    font-family: var(--fonts-mono);
    font-size: 0.8em;
    font-weight: 600;
    color: color-mix(in srgb, var(--colors-accent) 75%, var(--colors-fg));
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-16);
  }

  .project-card {
    display: grid;
    gap: var(--spacing-8);
    min-width: 0;
    padding: var(--spacing-16);
    border-radius: 6px;
    border: 1px solid rgba(245, 245, 247, 0.08);
    background: rgba(245, 247, 250, 0.04);
  }

  .project-card h4 {
    font-size: 1rem;
  }

  .project-role {
    margin: calc(var(--spacing-4) * -1) 0 0;
    color: color-mix(in srgb, var(--colors-muted) 88%, transparent);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-highlights {
    margin: 0 !important;
    padding-left: 1.05rem !important;
    font-size: 0.8125rem !important;
    line-height: 1.55 !important;
  }

  .skill-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--spacing-16);
  }

  .skill-group {
    display: grid;
    gap: var(--spacing-8);
    min-width: 0;
    padding-top: var(--spacing-12);
    border-top: 1px solid rgba(245, 245, 247, 0.08);
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  .skill-list li {
    border: 1px solid rgba(245, 245, 247, 0.1);
    padding: 0.24rem 0.48rem;
    color: color-mix(in srgb, var(--colors-fg) 72%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.04em;
  }

  .lang-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
    margin: 0 0 var(--spacing-8);
    padding: 0;
    list-style: none;
  }

  .lang-chips li {
    display: grid;
    gap: 2px;
    border: 1px solid rgba(245, 245, 247, 0.1);
    padding: 0.45rem 0.65rem;
    min-width: 7rem;
  }

  .lang-name {
    font-size: 0.8125rem;
    font-weight: 800;
    color: var(--colors-fg);
  }

  .lang-level {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
