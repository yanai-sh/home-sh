---
import { NOW, PROJECTS, READING, STACK, USES } from "@config/workspace";

const panes = [
  { id: "projects", label: "Projects" },
  { id: "stack", label: "Stack" },
  { id: "uses", label: "Uses" },
  { id: "reading", label: "Reading" },
  { id: "telemetry", label: "Telemetry" },
] as const;
---

<section
  class="workspace"
  id="systems"
  data-bg-variant="systems"
  aria-labelledby="systems-title"
  tabindex="-1"
>
  <header class="workspace-header">
    <h2 id="systems-title" class="section-heading section-heading--display">
      <span aria-hidden="true" class="slash">/</span> Systems
    </h2>
    <p class="section-deck">
      Integration surface, infra status, and Rust/WASM proofs running on the page.
    </p>
  </header>

  <section class="runtime-strip" aria-label="Runtime status">
    <p class="runtime-strip__label">runtime</p>
    <div class="runtime-items">
      {["wasm", "sab", "canvas", "search"].map((item) => (
        <span class="runtime-item" data-wip-status={item}>
          <span>{item}</span>
          <strong data-wip-value>pending</strong>
        </span>
      ))}
    </div>
  </section>

  <div class="workspace-shell">
    <nav class="pane-nav" aria-label="Systems panes">
      {panes.map((pane) => (
        <a href={`#${pane.id}`} data-pane-link={pane.id}>{pane.label}</a>
      ))}
    </nav>

    <div class="pane-stack">
      <section class="pane card pane--canvas" id="projects" data-pane aria-labelledby="sys-projects-title">
        <div class="pane-copy">
          <h3 id="sys-projects-title" class="section-heading section-heading--sub" tabindex="-1">
            <span aria-hidden="true" class="slash">/</span> Projects
          </h3>
          <p class="section-deck">Current build surface — Rust/WASM, infra, and integration work in flight.</p>
          <div class="project-list">
            {PROJECTS.map((project) => (
              <article class="card project-card">
                <p class="chapter-kicker">{project.status}</p>
                <h4>{project.title}</h4>
                <p>{project.description}</p>
                <div class="tag-row" aria-label={`${project.title} tags`}>
                  {project.tags.map((tag) => <span class="tag-chip">{tag}</span>)}
                </div>
                {project.href ? <a href={project.href}>source</a> : null}
              </article>
            ))}
          </div>
        </div>
        <div class="canvas-frame" aria-label="Rust canvas renderer">
          <canvas id="home-rust-canvas" width="720" height="420" aria-hidden="true"></canvas>
          <p>Rust lyon tessellation renders this surface when WASM is available.</p>
        </div>
      </section>

      <section class="pane card" id="stack" data-pane aria-labelledby="stack-title">
        <h3 id="stack-title" class="section-heading section-heading--sub" tabindex="-1">
          <span aria-hidden="true" class="slash">/</span> Stack
        </h3>
        <p class="section-deck">Working set — what the everyday loop actually runs on.</p>
        <div class="stack-grid">
          {STACK.map((row) => (
            <section aria-labelledby={`stack-${row.category}`}>
              <h4 id={`stack-${row.category}`}>{row.category}</h4>
              <ul>
                {row.items.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          ))}
        </div>
      </section>

      <section class="pane card" id="uses" data-pane aria-labelledby="uses-title">
        <h3 id="uses-title" class="section-heading section-heading--sub" tabindex="-1">
          <span aria-hidden="true" class="slash">/</span> Uses / now
        </h3>
        <p class="section-deck">Tools and current work.</p>
        <div class="uses-grid">
          <section id="now">
            <h4>now</h4>
            <ul>
              {NOW.map((item) => (
                <li>
                  <strong>{item.label}</strong>
                  {item.note ? <span>{item.note}</span> : null}
                </li>
              ))}
            </ul>
          </section>
          {USES.map((section) => (
            <section>
              <h4>{section.category}</h4>
              <ul>
                {section.items.map((item) => (
                  <li>
                    <strong>{item.label}</strong>
                    <span>{item.value}</span>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>

      <section class="pane card" id="reading" data-pane aria-labelledby="reading-title">
        <h3 id="reading-title" class="section-heading section-heading--sub" tabindex="-1">
          <span aria-hidden="true" class="slash">/</span> Reading
        </h3>
        <p class="section-deck">Queue and recent finishes — short shelves, regular rotation.</p>
        <div class="entry-list">
          {
            READING.map((item) => (
              <article class="entry">
                <header>
                  <h4>{item.title}</h4>
                  <p class="meta">
                    {item.author} · {item.status}
                  </p>
                </header>
              </article>
            ))
          }
        </div>
      </section>

      <section class="pane card" id="telemetry" data-pane aria-labelledby="telemetry-title">
        <h3 id="telemetry-title" class="section-heading section-heading--sub" tabindex="-1">
          <span aria-hidden="true" class="slash">/</span> Telemetry
        </h3>
        <p class="section-deck">
          Aggregate runtime data from yanai.sh over the last 30 days. No identifiers,
          no ad networks; the page works the same with telemetry blocked (DNT or{" "}
          <code>localStorage['telemetry:opt-out']='1'</code>).
        </p>
        <div class="telemetry-grid">
          <article>
            <h4>sessions</h4>
            <p>
              <strong data-telemetry-stat="total-sessions">—</strong>
              {" "}total ·{" "}
              <strong data-telemetry-stat="sessions-30d">—</strong>
              {" "}in last 30 days
            </p>
          </article>
          <article>
            <h4>performance</h4>
            <p>
              LCP <strong data-telemetry-stat="avg-lcp">—</strong> ·
              avg fps <strong data-telemetry-stat="avg-fps">—</strong>
            </p>
          </article>
          <article>
            <h4>geography &amp; device</h4>
            <p>
              <strong data-telemetry-stat="countries">—</strong>
            </p>
            <p>
              <strong data-telemetry-stat="devices">—</strong>
            </p>
          </article>
        </div>
      </section>
    </div>
  </div>
</section>

<style>
  .workspace {
    position: relative;
    z-index: 10;
    width: 100%;
    min-width: 0;
    padding:
      clamp(var(--spacing-48), 10vh, var(--spacing-96))
      max(var(--spacing-16), min(var(--spacing-48), 5vi))
      clamp(var(--spacing-64), 12vh, var(--spacing-96));
    box-sizing: border-box;
  }

  .workspace:focus {
    outline: none;
  }

  .workspace-header,
  .runtime-strip,
  .workspace-shell {
    width: min(76rem, 100%);
    margin-inline: auto;
  }

  .workspace-header {
    display: grid;
    gap: var(--spacing-8);
    max-width: 42rem;
    margin-bottom: clamp(var(--spacing-32), 5vw, var(--spacing-48));
  }

  .runtime-strip {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-16);
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-12) 0;
    border-top: 1px solid rgba(245, 245, 247, 0.1);
    border-bottom: 1px solid rgba(245, 245, 247, 0.1);
  }

  .runtime-strip__label {
    margin: 0;
    color: color-mix(in srgb, var(--colors-muted) 86%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .runtime-items {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }

  .runtime-item {
    display: inline-flex;
    gap: var(--spacing-8);
    min-height: 1.8rem;
    align-items: center;
    padding: 0 var(--spacing-8);
    border: 1px solid rgba(245, 245, 247, 0.1);
    color: color-mix(in srgb, var(--colors-fg) 68%, transparent);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .runtime-item strong {
    color: var(--colors-warning);
    font-size: 0.68rem;
  }

  .runtime-item[data-state="ready"] strong {
    color: color-mix(in srgb, var(--colors-accent) 78%, var(--colors-fg));
  }

  .runtime-item[data-state="error"] strong,
  .runtime-item[data-state="off"] strong {
    color: color-mix(in srgb, var(--colors-warning) 82%, var(--colors-fg));
  }

  .workspace-shell {
    display: grid;
    grid-template-columns: 10rem minmax(0, 1fr);
    gap: clamp(var(--spacing-24), 4vi, var(--spacing-48));
    padding-top: var(--spacing-48);
  }

  .pane-nav {
    position: sticky;
    top: var(--spacing-24);
    display: grid;
    align-content: start;
    gap: var(--spacing-8);
    height: fit-content;
  }

  .pane-nav a {
    padding: var(--spacing-8) 0;
    border-bottom: 1px solid rgba(245, 245, 247, 0.08);
    color: color-mix(in srgb, var(--colors-fg) 62%, transparent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .pane-nav a[aria-current="true"] {
    color: var(--colors-fg);
    border-bottom-color: color-mix(in srgb, var(--colors-accent) 62%, transparent);
  }

  .pane-stack {
    display: grid;
    gap: var(--spacing-24);
    min-width: 0;
  }

  .pane {
    scroll-margin-top: var(--spacing-24);
    display: grid;
    gap: var(--spacing-16);
    min-width: 0;
    padding: clamp(var(--spacing-16), 3vi, var(--spacing-32));
  }

  .pane--canvas {
    grid-template-columns: minmax(0, 0.88fr) minmax(18rem, 1fr);
    align-items: stretch;
  }

  .pane h4,
  .pane p {
    margin: 0;
  }

  .pane h4 {
    color: var(--colors-fg);
    font-size: 0.95rem;
    line-height: 1.35;
  }

  .pane .pane-copy {
    display: grid;
    gap: var(--spacing-16);
    min-width: 0;
  }

  .project-card p,
  .telemetry-grid p,
  .canvas-frame p {
    color: color-mix(in srgb, var(--colors-fg) 72%, transparent);
    font-family: var(--fonts-serif);
    line-height: 1.65;
  }

  .project-list,
  .stack-grid,
  .uses-grid,
  .telemetry-grid {
    display: grid;
    gap: var(--spacing-16);
  }

  .stack-grid section,
  .uses-grid section,
  .telemetry-grid article {
    display: grid;
    gap: var(--spacing-8);
    min-width: 0;
    padding-top: var(--spacing-12);
    border-top: 1px solid rgba(245, 245, 247, 0.08);
  }

  .project-card {
    display: grid;
    gap: var(--spacing-8);
    min-width: 0;
    padding: var(--spacing-16);
  }

  .project-card h4 {
    font-size: 1rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
  }

  .canvas-frame {
    position: relative;
    display: grid;
    align-content: end;
    min-height: 22rem;
    overflow: hidden;
    border: 1px solid rgba(245, 245, 247, 0.08);
    background: rgba(3, 5, 9, 0.42);
  }

  .canvas-frame canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .canvas-frame p {
    position: relative;
    z-index: 1;
    padding: var(--spacing-16);
    background: linear-gradient(180deg, transparent, rgba(10, 15, 24, 0.88));
  }

  .stack-grid,
  .uses-grid,
  .telemetry-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stack-grid ul,
  .uses-grid ul,
  .telemetry-grid ul {
    display: grid;
    gap: var(--spacing-8);
    margin: 0;
    padding: 0;
    list-style: none;
    color: color-mix(in srgb, var(--colors-fg) 72%, transparent);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  .uses-grid li {
    display: grid;
    gap: var(--spacing-4);
  }

  .uses-grid strong {
    color: var(--colors-fg);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 860px) {
    .workspace-shell,
    .pane--canvas,
    .stack-grid,
    .uses-grid,
    .telemetry-grid {
      grid-template-columns: 1fr;
    }

    .pane-nav {
      position: relative;
      top: auto;
      display: flex;
      overflow-x: auto;
      padding-bottom: var(--spacing-8);
    }

    .pane-nav a {
      white-space: nowrap;
      min-width: max-content;
    }

    .canvas-frame {
      min-height: 16rem;
    }
  }

  @media (max-width: 520px) {
    .workspace {
      padding-inline: var(--spacing-16);
    }

    .runtime-strip {
      align-items: flex-start;
      flex-direction: column;
    }

    .runtime-items {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .canvas-frame canvas {
      display: none;
    }
    .canvas-frame {
      display: none;
    }
    .pane--canvas {
      grid-template-columns: 1fr;
    }
  }

  .pane .entry {
    display: grid;
    gap: var(--spacing-8);
    padding-top: var(--spacing-12);
    border-top: 1px solid rgba(245, 245, 247, 0.08);
  }

  .pane .entry:first-of-type {
    padding-top: 0;
    border-top: none;
  }

  .pane .entry h4 {
    font-size: 1rem;
  }

  .pane .entry .meta {
    margin: 0;
    color: color-mix(in srgb, var(--colors-muted) 86%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }
</style>
