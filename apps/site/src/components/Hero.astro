---
import { SITE_BRAND } from "@config/site";

interface Props {
  /** Override when a second wordmark appears on the same document (e.g. `#systems`). */
  titleId?: string;
}

const { titleId = "hero-title" } = Astro.props;
---

<h1 id={titleId}>
  <span class="hero-wordmark">
    <span class="prefix">{SITE_BRAND.prefix}</span><span class="suffix text-accent">{SITE_BRAND.suffix}</span>
  </span>
</h1>

<style>
  h1 {
    font-size: clamp(2.5rem, 12vi, 10rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: 0;
    color: var(--colors-fg);
    margin-bottom: clamp(1.25rem, 3.5vi, 3rem);
    max-width: 100%;
    min-width: 0;
    user-select: none;
    cursor: default;
    /*
      1fr | auto | 1fr: middle column is exactly wordmark width; equal fr columns
      center that column in the full row.
    */
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: baseline;
    width: 100%;
  }

  .hero-wordmark {
    grid-column: 2;
    display: flex;
    flex-direction: row;
    align-items: baseline;
    column-gap: 0;
    max-width: 100%;
    min-width: 0;
    font-family: var(--fonts-mono);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .prefix {
    color: rgba(245, 247, 250, 0.98);
  }

  .text-accent {
    color: var(--colors-accent);
    font-weight: 800;
  }

  @media (max-width: 420px) {
    h1 {
      font-size: clamp(2.25rem, 11.5vi, 3.25rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .prefix {
      text-shadow: none;
    }

    .text-accent {
      text-shadow: none;
    }
  }
</style>
