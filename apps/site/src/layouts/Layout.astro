---
import '../styles/global.css';
import '@fontsource/ibm-plex-mono/index.css';
import '@fontsource/ibm-plex-serif/index.css';
import { SITE_OG_IMAGE_PATH, SITE_TITLE, SITE_URL } from '@config/site';

interface Props {
  title: string;
  description?: string;
  /** Target id for the skip link (must match the main content region on the page). */
  contentId?: string;
  robots?: 'index' | 'noindex';
}

const { title, description, contentId = 'main-content', robots = 'index' } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(SITE_OG_IMAGE_PATH, SITE_URL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/brand/favicon.svg?v=2" />
    <link rel="canonical" href={canonicalUrl} />
    {robots === 'noindex' ? <meta name="robots" content="noindex, nofollow" /> : null}
    {description ? <meta name="description" content={description} /> : null}
    <meta property="og:title" content={title} />
    {description ? <meta property="og:description" content={description} /> : null}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="yanai.sh wordmark on a slate background"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="yanai.sh wordmark on a slate background" />
    <meta name="theme-color" content="#151B22" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href={`#${contentId}`}>Skip to content</a>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    min-height: 100%;
  }

  body {
    min-height: 100dvh;
    overflow-x: hidden;
    overflow-y: auto;
    background: var(--colors-bg);
    color: var(--colors-fg);
    font-family: var(--fonts-mono);
    font-feature-settings: "calt" 1, "liga" 1;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .skip-link {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 100;
    padding: var(--spacing-12) var(--spacing-16);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--colors-bg);
    background: #2F6BFF;
    text-decoration: none;
    border-radius: 0 0 999px 0;
    transform: translateY(-120%);
    transition: transform 0.2s ease;
  }

  .skip-link:focus,
  .skip-link:focus-visible {
    transform: translateY(0);
    outline: 1px dashed rgba(47, 107, 255, 0.6);
    outline-offset: 2px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  :where(a, button, input, textarea, select, [tabindex]):focus-visible {
    outline: 1px dashed color-mix(in srgb, var(--colors-accent) 76%, transparent);
    outline-offset: 3px;
  }

  ::selection {
    background: rgba(47, 107, 255, 0.32);
    color: var(--colors-bg);
  }
</style>
