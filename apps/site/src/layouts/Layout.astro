---
import "../styles/global.css";
import "@fontsource/ibm-plex-mono/index.css";
import "@fontsource/ibm-plex-serif/index.css";
import { ClientRouter } from "astro:transitions";
import { SITE_OG_IMAGE_PATH, SITE_TITLE, SITE_URL } from "@config/site";

interface Props {
  title: string;
  description?: string;
  /** Target id for the skip link (must match the main content region on the page). */
  contentId?: string;
  robots?: "index" | "noindex";
  /** Opt-in Astro client router + view transitions (homepage only by default). */
  clientRouter?: boolean;
}

const {
  title,
  description,
  contentId = "main-content",
  robots = "index",
  clientRouter = false,
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(SITE_OG_IMAGE_PATH, SITE_URL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/brand/favicon.svg?v=2" />
    <link rel="canonical" href={canonicalUrl} />
    {robots === 'noindex' ? <meta name="robots" content="noindex, nofollow" /> : null}
    {description ? <meta name="description" content={description} /> : null}
    <meta property="og:title" content={title} />
    {description ? <meta property="og:description" content={description} /> : null}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="yanai.sh wordmark on a slate background"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="yanai.sh wordmark on a slate background" />
    <meta name="theme-color" content="#151B22" />
    <title>{title}</title>
    {clientRouter ? <ClientRouter /> : null}
  </head>
  <body>
    <a class="skip-link" href={`#${contentId}`}>Skip to content</a>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    min-height: 100%;
  }

  body {
    min-height: 100dvh;
    overflow-x: hidden;
    overflow-y: auto;
    background: var(--colors-bg);
    color: var(--colors-fg);
    font-family: var(--fonts-mono);
    font-feature-settings: "calt" 1, "liga" 1;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .skip-link {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 100;
    padding: var(--spacing-12) var(--spacing-16);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--colors-bg);
    background: #2F6BFF;
    text-decoration: none;
    border-radius: 0 0 999px 0;
    transform: translateY(-120%);
    transition: transform 0.2s ease;
  }

  .skip-link:focus,
  .skip-link:focus-visible {
    transform: translateY(0);
    outline: 1px dashed rgba(47, 107, 255, 0.6);
    outline-offset: 2px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  :where(a, button, input, textarea, select, [tabindex]):focus-visible {
    outline: 1px dashed color-mix(in srgb, var(--colors-accent) 76%, transparent);
    outline-offset: 3px;
  }

  ::selection {
    background: rgba(47, 107, 255, 0.32);
    color: var(--colors-bg);
  }

  .chapter-kicker {
    margin: 0;
    color: color-mix(in srgb, var(--colors-muted) 86%, transparent);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  /*
   * Section heading: slash + label, sentence-cased.
   * Inspired by nbakh16/career-portfolio-template: "<span class='slash'>/</span> Section Name".
   */
  .section-heading {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    color: var(--colors-fg);
    font-family: var(--fonts-mono);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .section-heading--display {
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  .section-heading--sub {
    font-size: clamp(1.25rem, 2.4vw, 1.75rem);
  }

  .section-heading .slash {
    color: var(--colors-accent);
    font-weight: 800;
    flex-shrink: 0;
  }

  .section-deck {
    max-width: 36rem;
    margin: var(--spacing-12) 0 0;
    color: color-mix(in srgb, var(--colors-fg) 62%, transparent);
    font-family: var(--fonts-serif);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .section-deck a {
    color: color-mix(in srgb, var(--colors-accent) 78%, var(--colors-fg));
    text-underline-offset: 0.2em;
  }

  .section-deck code {
    font-family: var(--fonts-mono);
    font-size: 0.85em;
    font-weight: 600;
    color: color-mix(in srgb, var(--colors-accent) 72%, var(--colors-fg));
  }

  /*
   * Card surface: subtle accent tint, lifts on hover.
   * Inspired by nbakh16/career-portfolio-template's `bg-accent/5 border-accent/10 rounded-2xl hover:border-accent/40` recipe.
   */
  .card {
    border: 1px solid color-mix(in srgb, var(--colors-accent) 12%, transparent);
    border-radius: 12px;
    background: color-mix(in srgb, var(--colors-accent) 5%, transparent);
    transition:
      border-color 0.3s ease,
      background-color 0.3s ease;
  }

  .card:hover,
  .card:focus-within {
    border-color: color-mix(in srgb, var(--colors-accent) 40%, transparent);
    background: color-mix(in srgb, var(--colors-accent) 8%, transparent);
  }

  /*
   * Tag chip: small accent-tinted pill. Brightens when the parent .card is hovered.
   */
  .tag-chip {
    display: inline-flex;
    align-items: center;
    border: 1px solid color-mix(in srgb, var(--colors-accent) 18%, transparent);
    border-radius: 6px;
    padding: 0.22rem 0.55rem;
    color: color-mix(in srgb, var(--colors-accent) 72%, var(--colors-fg));
    background: color-mix(in srgb, var(--colors-accent) 5%, transparent);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1.2;
    text-transform: uppercase;
    transition:
      border-color 0.3s ease,
      color 0.3s ease;
  }

  .card:hover .tag-chip,
  .card:focus-within .tag-chip {
    border-color: color-mix(in srgb, var(--colors-accent) 40%, transparent);
    color: color-mix(in srgb, var(--colors-accent) 92%, var(--colors-fg));
  }
</style>
