---
import '../styles/global.css';
import { SITE_DESCRIPTION, SITE_OG_IMAGE_PATH, SITE_TITLE, SITE_URL } from '@config/site';

interface Props {
  title: string;
}

const { title } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(SITE_OG_IMAGE_PATH, SITE_URL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/brand/favicon.svg?v=2" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={SITE_DESCRIPTION} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={SITE_DESCRIPTION} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={SITE_DESCRIPTION} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta id="theme-color-meta" name="theme-color" content="#151B22" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <div class="systems-field-layer" aria-hidden="true" data-systems-field-layer>
      <canvas data-systems-field-canvas></canvas>
    </div>
    <slot />

    <button id="to-top" class="to-top" type="button" aria-label="Back to top">
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="M12 5l-7 7 1.4 1.4 4.6-4.58V20h2V8.82l4.6 4.58L19 12z"></path>
      </svg>
    </button>

    <script>
      import '../scripts/portfolio-root-client';
    </script>
  </body>
</html>

<style is:global>
  .to-top {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 50;
    display: grid;
    width: 2.9rem;
    height: 2.9rem;
    place-items: center;
    border: 1px solid var(--color-rule-strong);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface-raised) 90%, transparent);
    color: var(--color-maintext);
    box-shadow: var(--shadow-soft);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.75rem);
    transition:
      opacity 160ms ease,
      transform 160ms ease,
      border-color 160ms ease;
  }

  .systems-field-layer {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .systems-field-layer canvas {
    width: 100%;
    height: 100%;
    opacity: 0;
    mix-blend-mode: screen;
    transition: opacity 700ms ease;
  }

  .systems-field-layer.is-systems-field-ready canvas {
    opacity: 0.42;
  }

  [data-theme='light'] .systems-field-layer.is-systems-field-ready canvas {
    opacity: 0.36;
    mix-blend-mode: multiply;
  }

  .systems-field-debug {
    position: fixed;
    right: 1rem;
    bottom: 4.35rem;
    z-index: 60;
    display: grid;
    gap: 0.2rem;
    min-width: 11rem;
    border: 1px solid var(--color-rule-strong);
    border-radius: 8px;
    padding: 0.65rem 0.75rem;
    background: color-mix(in srgb, var(--color-background) 86%, transparent);
    color: var(--color-subtext);
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem;
    line-height: 1.35;
    backdrop-filter: blur(18px);
    pointer-events: none;
  }

  .site-header,
  .site-shell {
    position: relative;
    z-index: 1;
  }

  .to-top.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .to-top:hover {
    border-color: var(--color-accent);
  }

  .to-top svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: currentColor;
  }
</style>
