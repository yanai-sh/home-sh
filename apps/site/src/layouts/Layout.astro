---
import '../styles/global.css';
import { SITE_DESCRIPTION, SITE_OG_IMAGE_PATH, SITE_TITLE, SITE_URL } from '@config/site';

interface Props {
  title: string;
}

const { title } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(SITE_OG_IMAGE_PATH, SITE_URL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/brand/favicon.svg?v=2" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={SITE_DESCRIPTION} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={SITE_DESCRIPTION} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={SITE_DESCRIPTION} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta id="theme-color-meta" name="theme-color" content="#151B22" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot />

    <button id="to-top" class="to-top" type="button" aria-label="Back to top">
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="M12 5l-7 7 1.4 1.4 4.6-4.58V20h2V8.82l4.6 4.58L19 12z"></path>
      </svg>
    </button>

    <script>
      import '../scripts/portfolio-root-client';
    </script>
  </body>
</html>

<style is:global>
  .to-top {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 50;
    display: grid;
    width: 2.9rem;
    height: 2.9rem;
    place-items: center;
    border: 1px solid var(--color-rule-strong);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface-raised) 90%, transparent);
    color: var(--color-maintext);
    box-shadow: var(--shadow-soft);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.75rem);
    transition:
      opacity 160ms ease,
      transform 160ms ease,
      border-color 160ms ease;
  }

  .to-top.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .to-top:hover {
    border-color: var(--color-accent);
  }

  .to-top svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: currentColor;
  }
</style>
