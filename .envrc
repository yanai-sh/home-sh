# Loaded by direnv when entering the repo. Run `direnv allow` once per machine.
# Decrypts infra/tofu/secrets.enc.json with the local age key and exports each
# top-level key as an environment variable, named in upper-case.
#
# Astro reads PUBLIC_TURNSTILE_SITE_KEY at build time. The other secrets
# (TURNSTILE_SECRET / RESEND_API_KEY / CONTACT_FROM / CONTACT_TO) are bound to
# the deployed site Worker via `wrangler secret put`; local `wrangler dev`
# picks them up from the same env vars below if the Astro API route at
# /api/contact is exercised in dev.

# Ensure age key is reachable (no-op export — used by sops below).
export SOPS_AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt"

if [[ -r infra/tofu/secrets.enc.json && -r "$SOPS_AGE_KEY_FILE" ]]; then
  # Decrypt to JSON, then export each top-level key as UPPERCASE env var.
  while IFS=$'\t' read -r key value; do
    [[ -z "$key" ]] && continue
    upper="$(echo "$key" | tr '[:lower:]' '[:upper:]')"
    export "$upper=$value"
  done < <(
    sops --decrypt --input-type json --output-type json infra/tofu/secrets.enc.json \
      | jq -r 'to_entries[] | [.key, .value] | @tsv'
  )
fi
