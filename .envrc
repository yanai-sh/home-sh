# Loaded by direnv when entering the repo. Run `direnv allow` once per machine.
#
# Exports keys from infra/secrets/worker-secrets.local.json (gitignored) as
# UPPER_SNAKE_CASE env vars for local scripts and optional Wrangler use.
# For Astro, prefer apps/site/.dev.vars (see CONTRIBUTING.md).

if [[ -r infra/secrets/worker-secrets.local.json ]]; then
  while IFS=$'\t' read -r key value; do
    [[ -z "$key" ]] && continue
    upper="$(echo "$key" | tr '[:lower:]' '[:upper:]')"
    export "$upper=$value"
  done < <(
    jq -r 'to_entries[] | [.key, .value] | @tsv' infra/secrets/worker-secrets.local.json
  )
fi
