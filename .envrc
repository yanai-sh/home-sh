# Loaded by direnv when entering the repo. Run `direnv allow` once per machine.
#
# Exports keys from infra/secrets/worker-secrets.local.json (gitignored) as
# UPPER_SNAKE_CASE env vars for local scripts and optional Wrangler use.
# For Astro, prefer apps/site/.dev.vars (see AGENTS.md).

if [[ -r infra/secrets/worker-secrets.local.json ]]; then
  while IFS=$'\t' read -r key value; do
    [[ -z "$key" ]] && continue
    upper="$(echo "$key" | tr '[:lower:]' '[:upper:]')"
    export "$upper=$value"
  done < <(
    jq -r 'to_entries[] | [.key, .value] | @tsv' infra/secrets/worker-secrets.local.json
  )
fi

# Git + gh: yanai-sh for github.com only while this directory is loaded (unset when you leave).
# Uses Git 2.31+ GIT_CONFIG_* (higher precedence than file config). Does not touch ~/.gitconfig.
export GIT_CONFIG_COUNT=2
export GIT_CONFIG_KEY_0=credential.https://github.com.username
export GIT_CONFIG_VALUE_0=yanai-sh
export GIT_CONFIG_KEY_1=url.https://yanai-sh@github.com/.insteadOf
export GIT_CONFIG_VALUE_1=https://github.com/

if command -v gh >/dev/null 2>&1; then
  _ghys_tok="$(GH_PROMPT_DISABLED=1 gh auth token -h github.com -u yanai-sh 2>/dev/null)" || true
  if [[ -n "${_ghys_tok:-}" ]]; then
    export GH_TOKEN="${_ghys_tok}"
  fi
  unset _ghys_tok
fi
